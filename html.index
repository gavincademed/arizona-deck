<div class="bc w2 dark"><div class="pre">Patient Experience</div><div class="n">Real<span class="x" style="font-size:.5em">&nbsp;people</span></div><div class="s">No AI calling. No call centers. The same designated care member every week. Medicare-backed, FDA-cleared devices.</div></div>
<div class="bc w2 feat"><div class="ic">Local</div><div class="ft">A rep in your market</div><div class="s">Same time zone, same community, real accountability in person.</div></div>
</div></div>

<div class="r" data-d="0.2"><div class="cta-wrap">
<div class="cta-l"><h2>Extend your care into the home.<br>Engage your patients.<br><span class="ac">Open a new revenue line.</span></h2><a href="mailto:coy@cademed.com,gavin@cademed.com?subject=Connected%20Care%20with%20CADE&amp;body=Hi%20Coy%20and%20Gavin%2C%0A%0AWe%27d%20like%20to%20get%20started%20with%20CADE%20Connected%20Care.%20When%20can%20we%20talk%20through%20next%20steps%3F%0A%0AThank%20you%2C" class="cta-btn">Reach Out Today<svg viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7h12m0 0L7 1m6 6l-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></a></div><div class="cta-r"><div class="contact"><span class="t">Primary contact</span><span class="n">Coy DeJong</span><span class="t" style="margin-top:2px">CADE Connected Care</span><a href="mailto:coy@cademed.com,gavin@cademed.com" class="e">coy@cademed.com</a></div></div></div></div>

<div class="r" data-d="0.5" style="margin-top:36px;text-align:center"><img src="https://imagedelivery.net/qJvpJU9hpeX3lEcmqZfcwg/ea71bdc8-b2c0-4c20-b8a2-e702a7164900/public" alt="CADE" style="height:32px;object-fit:contain;margin:0 auto 10px;opacity:.5"><div style="font-family:var(--mo);font-size:10.5px;color:var(--lg);letter-spacing:2.5px;text-transform:uppercase;font-weight:500">Confidential &middot; Prepared for your practice</div></div></div></section>

<script>
(function(){
var mp=document.getElementById('mp');
var NAV=[['cover','COVER'],['why-now','WHY THIS, WHY NOW'],['offplate','OFF YOUR PLATE'],['timeback','THE WORKFLOW'],['kit','PROGRAMS &amp; KIT'],['why','THE PROBLEM'],['ffs','FFS REVENUE'],['cadeprice','CADE PRICING'],['whycade','WHY CADE'],['calc','THE NUMBERS'],['close','CLOSE']];
var ai=0,idxEl=document.getElementById('mpidx'),lbEl=document.getElementById('mplb'),totEl=document.getElementById('mptot'),upEl=document.getElementById('mpup'),dnEl=document.getElementById('mpdn');
var pad=function(n){return String(n).padStart(2,'0')};
totEl.textContent='/ '+pad(NAV.length);
function setNav(i){ai=i;idxEl.textContent=pad(i+1);lbEl.textContent=NAV[i][1];upEl.disabled=i===0;dnEl.disabled=i===NAV.length-1}
setNav(0);
var scrollEl=mp.parentElement;
while(scrollEl&&scrollEl!==document.body){
  var oy=window.getComputedStyle(scrollEl).overflowY;
  if(oy==='auto'||oy==='scroll')break;
  scrollEl=scrollEl.parentElement;
}
if(!scrollEl||scrollEl===document.body)scrollEl=window;
var progEl=document.getElementById('mpprog');
var blobEl=mp.querySelector('.blob');
function updateActive(){
  var viewportH=scrollEl===window?window.innerHeight:scrollEl.clientHeight;
  var viewportCenterY=viewportH/2;
  var bestIdx=0;
  var bestDist=Infinity;
  for(var i=0;i<NAV.length;i++){
    var el=document.getElementById('mp-'+NAV[i][0]);
    if(!el)continue;
    var rect=el.getBoundingClientRect();
    var scrollRect=scrollEl===window?{top:0}:scrollEl.getBoundingClientRect();
    var sectionCenterInViewport=(rect.top-scrollRect.top)+rect.height/2;
    var dist=Math.abs(viewportCenterY-sectionCenterInViewport);
    if(dist<bestDist){bestDist=dist;bestIdx=i}
  }
  if(bestIdx!==ai)setNav(bestIdx);
  var scrollTop=scrollEl===window?window.scrollY:scrollEl.scrollTop;
  var scrollH=scrollEl===window?(document.documentElement.scrollHeight-window.innerHeight):(scrollEl.scrollHeight-scrollEl.clientHeight);
  var pct=scrollH>0?Math.min(100,Math.max(0,(scrollTop/scrollH)*100)):0;
  if(progEl)progEl.style.width=pct+'%';
  if(blobEl){var bo=scrollTop*-0.15;blobEl.style.transform='translateY('+bo+'px)'}
}
var scrollTimer;
function onScroll(){
  if(scrollTimer)cancelAnimationFrame(scrollTimer);
  scrollTimer=requestAnimationFrame(updateActive);
}
scrollEl.addEventListener('scroll',onScroll,{passive:true});
window.addEventListener('resize',onScroll,{passive:true});
updateActive();
var robsRoot=scrollEl===window?null:scrollEl;
var robs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('v');robs.unobserve(e.target)}})},{root:robsRoot,threshold:.12});
function obsR(){mp.querySelectorAll('.r:not(.v)').forEach(function(el){if(!el.dataset.o){el.dataset.o='1';var d=el.getAttribute('data-d');if(d)el.style.transitionDelay=d+'s';robs.observe(el)}})}
upEl.onclick=function(){if(ai>0){var target=document.getElementById('mp-'+NAV[ai-1][0]);if(target){setNav(ai-1);target.scrollIntoView({behavior:'smooth',block:'start'})}}};
dnEl.onclick=function(){if(ai<NAV.length-1){var target=document.getElementById('mp-'+NAV[ai+1][0]);if(target){setNav(ai+1);target.scrollIntoView({behavior:'smooth',block:'start'})}}};

/* Why CADE stats */
var stats=[['30K+','Patients on our platform'],['20+','Chronic conditions'],['12yr','Platform experience']];
var stH='';stats.forEach(function(s,i){stH+='<div class="r st" data-d="'+(0.2+i*.07)+'"><div class="n">'+s[0]+'</div><div class="l">'+s[1]+'</div></div>'});
document.getElementById('mp-stats').innerHTML=stH;

/* Why CADE differentiators */
var diffs=['Local Reps, In Person','Patient Experience First','12+ Years Running This','Character of Ownership','DME &amp; CGM Licensed Direct','Priced ~20% Below Market'];
var dH='';diffs.forEach(function(d,i){dH+='<div class="r" data-d="'+(0.3+i*.05)+'"><div class="card ac diff diff-title"><h3>'+d+'</h3></div></div>'});
document.getElementById('mp-diffs').innerHTML=dH;

/* Spend bars */
var spend=[['Circulatory (HTN, Heart Attack)',234,1],['Prevention &amp; Basic Care',207,0],['Musculoskeletal',170,0],['Respiratory (COPD, Asthma)',144,1],['Endocrine (Diabetes)',126,1],['Nervous System',120,0],['Cancers',116,0]];
var spH='';spend.forEach(function(d){var w=Math.round(d[1]/234*100);var c1=d[2]?'var(--c)':'var(--lg)';var c2=d[2]?'var(--c)':'rgba(255,255,255,.12)';spH+='<div class="row"><span class="lbl2" style="color:'+c1+'">'+d[0]+'</span><div class="bar"><div style="width:'+w+'%;background:'+c2+'"></div></div><span class="val" style="color:'+c1+'">$'+d[1]+'B</span></div>'});
document.getElementById('mp-spend').innerHTML=spH;

/* Team: lead card + combined field card */
var team=[
  ['Coy DeJong','Connected Care AE',['Out in the field with your providers and patients','Drives education, engagement, and enrollment','Day-to-day point of contact'],true,'data:image/jpeg;base64,']
];
var teH='';
team.forEach(function(p){
  if(!p[3])return;
  var itm='';p[2].forEach(function(i){itm+='<div class="tmi"><span class="dash">&middot;</span><span class="txt">'+i+'</span></div>'});
  var lav=p[4]?'<img src="'+p[4]+'" alt="'+p[0]+'" onerror="this.parentNode.innerHTML=\'<span>'+p[0][0]+'</span>\'">':'<span>'+p[0][0]+'</span>';
  teH+='<div class="card tm lead"><div class="hd"><div class="av">'+lav+'</div><div><div class="nm">'+p[0]+'</div><div class="tt">'+p[1]+'</div></div></div>'+itm+'</div>';
});
var fieldMembers=team.filter(function(p){return !p[3]});
if(fieldMembers.length){
  var people='';fieldMembers.forEach(function(p){
    var parts=p[0].split(' ');var ini=parts[0][0]+(parts[1]?parts[1][0]:'');
    var fav=p[4]?'<img src="'+p[4]+'" alt="'+p[0]+'" onerror="this.parentNode.innerHTML=\'<span style=&quot;font-family:var(--se);font-style:italic;font-size:22px;color:var(--c)&quot;>'+ini+'</span>\'">':'<span style="font-family:var(--se);font-style:italic;font-size:22px;color:var(--c)">'+ini+'</span>';
    people+='<div class="ft-person"><div class="av">'+fav+'</div><div class="ft-nm">'+p[0]+'</div><div class="ft-tt">'+p[1]+'</div></div>';
  });
  var sharedBullets=['Out in the field with your providers and patients','Drives education, engagement, enrollment, and monthly performance reviews','Day-to-day point of contact'];
  var b='';sharedBullets.forEach(function(i){b+='<div class="tmi"><span class="dash">&middot;</span><span class="txt">'+i+'</span></div>'});
  teH+='<div class="card tm field"><div class="ft-row">'+people+'</div><div class="ft-bullets">'+b+'</div></div>';
}
document.getElementById('mp-team').innerHTML=teH;

function rosterH(people){var h='';people.forEach(function(p){var parts=p[0].split(' ');var ini=parts[0][0]+(parts[1]?parts[1][0]:'');var avContent=p[2]?'<img src="'+p[2]+'" alt="'+p[0]+'" onerror="this.parentNode.innerHTML=\'<span>'+ini+'</span>\'">':'<span>'+ini+'</span>';h+='<div class="roster"><div class="av">'+avContent+'</div><div class="nm">'+p[0]+'</div><div class="tt">'+p[1]+'</div></div>'});return h}
var csTeam=[['Diane Chavez','Director','https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/78d44313-5754-44c5-116a-0b8b1726ce00/public'],['Anna Gaskin','Manager','https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/c538eb44-3c42-4bab-d9df-7ea488097900/public']];
var ctTeam=[['Stefanie Maier','Director','https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/dd469f36-213d-402b-5ff7-48be15d0f700/public'],['Stacy Gillham','Manager','https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/a1398e9d-549f-4b9b-d848-347fd76e5e00/public'],['Felicia Rhoden','Manager','https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/e2382615-908a-4a72-e518-67e45142ef00/public'],['Amanda Lopez','Manager','https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/c044227f-ecfb-4dd8-9165-d213b521df00/public']];
document.getElementById('mp-cs-team').innerHTML=rosterH(csTeam);
document.getElementById('mp-ct-team').innerHTML=rosterH(ctTeam);

/* ROI CALCULATOR */
(function(){
  var PMPM_DUAL=297, PMPM_STD=160;
  var el=function(id){return document.getElementById(id);};
  var S={total:el('cs-total'),elig:el('cs-elig'),chron:el('cs-chron'),acc:el('cs-acc'),dual:el('cs-dual')};
  if(!S.total)return;
  var nf=function(n){return Math.round(n).toLocaleString('en-US');};
  var money=function(n){return '$'+Math.round(n).toLocaleString('en-US');};
  var big=function(n){if(n>=1e6)return '$'+(n/1e6).toFixed(2).replace(/\.?0+$/,'')+'M';if(n>=1e3)return '$'+(n/1e3).toFixed(0)+'K';return '$'+Math.round(n);};
  var mark=function(mid,val){var m=el(mid);if(m)m.style.left=val+'%';};
  mark('ma-elig',40);mark('ma-chron',85);mark('ma-acc',50);mark('ma-dual',80);
  function calc(){
    var total=+S.total.value, elig=+S.elig.value/100, chron=+S.chron.value/100, acc=+S.acc.value/100, dual=+S.dual.value/100;
    el('cv-total').textContent=nf(total);
    el('cv-elig').textContent=S.elig.value+'%';
    el('cv-chron').textContent=S.chron.value+'%';
    el('cv-acc').textContent=S.acc.value+'%';
    el('cv-dual').textContent=S.dual.value+'%';
    var eligN=total*elig, chronN=eligN*chron, enrN=chronN*acc;
    var dualN=enrN*dual, stdN=enrN-dualN;
    var mo=dualN*PMPM_DUAL+stdN*PMPM_STD, yr=mo*12;
    el('co-elig').textContent=nf(eligN);
    el('co-chron').textContent=nf(chronN);
    el('co-enr').textContent=nf(enrN);
    el('co-mo').textContent=money(mo);
    el('co-yr').textContent=big(yr);
    el('co-detail').innerHTML=nf(dualN)+' dual-enrolled at $297/mo &middot; '+nf(stdN)+' at $160/mo';
  }
  Object.keys(S).forEach(function(k){S[k].addEventListener('input',calc);});
  calc();
})();

obsR();
})();
</script>
</div>
