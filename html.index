<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>CADE · Connected Care Proposal</title>
<meta name="description" content="A Connected Care fee-for-service proposal from CADE. Proactive, in-home chronic care that extends the practice and opens a new Medicare-backed revenue line.">
<meta property="og:type" content="website">
<meta property="og:title" content="CADE · Connected Care Proposal">
<meta property="og:description" content="Proactive, in-home chronic care that extends your practice and opens a new Medicare-backed revenue line.">
<meta property="og:image" content="https://imagedelivery.net/qJvpJU9hpeX3lEcmqZfcwg/ea71bdc8-b2c0-4c20-b8a2-e702a7164900/public">
<meta property="og:image:alt" content="CADE Medical">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="CADE · Connected Care Proposal">
<meta name="twitter:description" content="A Connected Care fee-for-service proposal from CADE.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Fraunces:ital,opsz,wght,SOFT,WONK@1,9..144,400..900,0..100,0..1&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box}
html,body{margin:0;padding:0;width:100%;height:100%;overflow:hidden;background:#F4EFE7;font-family:'Inter',sans-serif}
#deck{display:block;width:100%;height:100%;overflow:auto;scroll-behavior:smooth;scroll-snap-type:y proximity}
@media (prefers-reduced-motion:reduce){
  #deck{scroll-behavior:auto;scroll-snap-type:none}
  *,*::before,*::after{animation-duration:.01ms !important;animation-iteration-count:1 !important;transition-duration:.01ms !important;scroll-behavior:auto !important}
}
</style>
</head>
<body>

<noscript>
<div style="padding:60px 24px;max-width:520px;margin:80px auto;text-align:center;font-family:'Inter',sans-serif;background:#EBE3D2;border-radius:16px">
<h2 style="font-family:'Fraunces',serif;font-style:italic;font-weight:400;color:#0B1320;font-size:28px;margin:0 0 16px">JavaScript Required</h2>
<p style="color:#41546B;line-height:1.6;font-size:15px;margin:0 0 20px">This proposal uses interactive elements that require JavaScript. Please enable JavaScript in your browser, or contact us for a PDF version.</p>
<p style="font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:2px;color:#999;text-transform:uppercase">CADE &middot; coy@cademed.com</p>
</div>
</noscript>

<div id="deck">
<div class="mp" id="mp">
<style>
.mp{
--bg:#F4EFE7;--c:#2A72B0;--cb:rgba(42,114,176,.07);
--c-vivid:#41B8CA;--c-warm:#C9A77C;--c-warm-ink:#A87C42;
--d:#0B1320;--gy:#41546B;--lg:#7A8694;--ulg:#BFD0E4;
--gl:rgba(11,19,32,.03);--gb:rgba(11,19,32,.08);--gh:rgba(11,19,32,.12);
--w:#F8FAFC;--kb:#EBE3D2;
--gr:linear-gradient(143deg,#04070D 0%,#0A1626 46%,#14294A 100%);
--mo:"JetBrains Mono","Roboto Mono",monospace;
--se:"Fraunces",Georgia,serif;
--sa:"Inter","Montserrat",sans-serif;
font-family:var(--sa);background:var(--bg);color:var(--d);position:relative;box-sizing:border-box;font-size:15px;line-height:1.5}
/* CADE accent law: vivid aqua becomes the accent on dark surfaces, where it earns contrast and reads electric. */
.mp .gbg,.mp .dcard,.mp .bc.dark,.mp .bc.hero,.mp .cta-wrap,.mp .prc-hero,.mp .risk-box.dk,.mp .glass.dk,.mp .pill.dk,.mp .pd-dark{--c:#41B8CA;--cb:rgba(65,184,202,.08)}
.mp *,.mp *::before,.mp *::after{box-sizing:border-box}
.mp{overflow-wrap:break-word}
.mp button{font:inherit;color:inherit}
.mp img{max-width:100%;display:block}
.mp h1,.mp h2,.mp h3,.mp h4,.mp p{margin:0}
.mp .blob{position:fixed;top:-20%;right:-15%;width:600px;height:600px;border-radius:50%;background:rgba(42,114,176,.06);filter:blur(90px);pointer-events:none;z-index:0;will-change:transform;transition:transform .15s ease-out}
.mp section{position:relative;z-index:1;padding:clamp(72px,9vh,120px) clamp(20px,5vw,64px);min-height:100vh;display:flex;flex-direction:column;justify-content:center;scroll-snap-align:start;scroll-snap-stop:normal}
.mp .sct{justify-content:flex-start;padding-top:clamp(92px,11vh,140px)}
.mp .ctr{align-items:center;text-align:center}
.mp .gbg{background:var(--gr)}
.mp .cbg{background:var(--cb)}
.mp .wrap{width:100%;max-width:1200px;margin:0 auto;display:flex;flex-direction:column}
.mp .ctr .wrap{align-items:center}
.mp .lbl{font-family:var(--mo);font-weight:500;letter-spacing:2.5px;color:var(--gy);text-transform:uppercase;display:block;line-height:1.4;font-size:14px}
.mp .lbl-c{color:var(--c);font-size:14px;font-weight:500}
.mp .lbl-lg{color:var(--ulg);font-size:12px;letter-spacing:3px}
.mp .lbl-lgc{color:var(--c);font-size:14px;font-weight:500}
.mp .lbl-cov{font-size:15px;letter-spacing:6px;color:var(--gy);font-weight:500}
.mp h1,.mp h2,.mp h3{font-family:var(--se);font-style:italic;font-weight:400;letter-spacing:-.01em}
.mp .h1{font-size:clamp(44px,6.5vw,84px);color:var(--d);line-height:1.02;margin:14px 0 10px}
.mp .h1w{color:var(--w)}
.mp .h2{font-size:clamp(32px,5vw,60px);color:var(--d);line-height:1.05;margin:14px 0 22px;max-width:820px}
.mp .h2w{color:var(--w)}
.mp .ac{color:var(--c)}
.mp .h3{font-size:22px;color:var(--d);margin:0}
.mp .h3w{color:var(--w)}
.mp p{font-family:var(--sa);font-size:15px;color:var(--gy);line-height:1.7}
.mp p.intro{max-width:680px;margin-bottom:clamp(28px,4vh,44px)}
.mp p.w{color:var(--ulg)}
.mp p.sm{font-size:13px;line-height:1.6}
.mp .num{font-family:var(--sa);font-size:13px;font-weight:700;color:var(--c);display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:10px;background:var(--cb);letter-spacing:.5px;margin-bottom:14px}
.mp .num.dk{color:var(--c);background:rgba(255,255,255,.08)}
.mp .pill{font-family:var(--mo);font-size:9.5px;font-weight:500;letter-spacing:1.8px;text-transform:uppercase;color:var(--w);padding:6px 14px;border-radius:20px;display:inline-block;background:var(--c);white-space:nowrap;line-height:1}
.mp .pill.dk{background:var(--d)}
.mp .pill.big{font-size:12px;letter-spacing:2.2px;padding:10px 22px}
.mp .card{background:var(--kb);border-radius:16px;padding:26px 28px;border:1px solid rgba(0,0,0,.04);box-shadow:0 2px 12px rgba(0,0,0,.02)}
.mp .card.ac{border-top:2px solid var(--c)}
.mp .dcard{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:22px 26px}
.mp .dcard.ac{border-left:2px solid var(--c)}
.mp .dv{width:52px;height:2px;background:var(--c);margin:36px 0}
.mp .ctr .dv{margin-left:auto;margin-right:auto}
.mp .r{opacity:0;transform:translateY(24px);transition:opacity .75s cubic-bezier(.16,1,.3,1),transform .75s cubic-bezier(.16,1,.3,1);will-change:opacity,transform}
.mp .r.v{opacity:1;transform:translateY(0)}
.mp a.src-link:focus-visible,.mp a[href^="mailto"]:focus-visible{outline:2px solid var(--c);outline-offset:2px;border-radius:4px}

/* Nav */
.mp .nav{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:100;display:flex;align-items:center;background:rgba(244,239,231,.88);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:40px;border:1px solid rgba(0,0,0,.06);box-shadow:0 4px 24px rgba(0,0,0,.06);overflow:hidden;transition:all .4s ease;font-family:var(--sa)}
.mp .nav .prog-track{position:absolute;top:0;left:0;right:0;height:2px;background:rgba(42,114,176,.12);pointer-events:none}
.mp .nav .prog-fill{height:100%;background:var(--c);width:0%;transition:width .35s cubic-bezier(.16,1,.3,1);border-radius:0 2px 2px 0}
.mp .nav .ch{background:none;border:none;cursor:pointer;padding:10px 14px;opacity:.5;transition:opacity .3s;display:flex;align-items:center;justify-content:center;color:var(--d)}
.mp .nav .ch:hover:not(:disabled){opacity:1}
.mp .nav .ch:focus-visible{outline:2px solid var(--c);outline-offset:-2px;border-radius:8px;opacity:1}
.mp .nav .ch:disabled{opacity:.15;cursor:default}
.mp .nav .ch svg{width:14px;height:8px}
.mp .nav .ch.up svg{transform:rotate(180deg)}
.mp .nav .inf{display:flex;align-items:center;gap:10px;padding:8px 4px;min-width:54px;transition:min-width .4s ease;overflow:hidden;justify-content:center}
.mp .nav:hover .inf{min-width:170px}
.mp .nav .idx{font-family:var(--mo);font-size:12px;color:var(--c);letter-spacing:.5px;flex-shrink:0;font-weight:500;text-transform:uppercase}
.mp .nav .lb{font-family:var(--mo);font-size:9.5px;color:var(--lg);letter-spacing:2px;text-transform:uppercase;white-space:nowrap;max-width:0;opacity:0;transition:all .4s ease}
.mp .nav:hover .lb{max-width:140px;opacity:1}
.mp .nav .tot{font-family:var(--mo);font-size:12px;color:rgba(0,0,0,.25);flex-shrink:0;opacity:0;transition:opacity .3s;text-transform:uppercase}
.mp .nav:hover .tot{opacity:1}

/* Grids */
.mp .g2{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;grid-auto-rows:1fr}
.mp .g3{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;grid-auto-rows:1fr}
.mp .g2>.r,.mp .g3>.r{height:100%}
.mp .g2>.r>*,.mp .g3>.r>*{height:100%}

/* Cover */
.mp .covlog{height:44px;object-fit:contain}
.mp .covprep{display:flex;flex-direction:column;align-items:center;gap:10px}
.mp .covbox{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:24px;max-width:520px;margin-left:auto;margin-right:auto;width:100%}
.mp .covbx{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:14px;padding:22px 20px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;min-height:120px;text-align:center}
.mp .covbx-prog{background:linear-gradient(135deg,rgba(42,114,176,.12) 0%,rgba(42,114,176,.03) 100%);border-color:rgba(42,114,176,.28)}
.mp .covbx-n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(32px,3.8vw,44px);color:var(--c);line-height:1;letter-spacing:-.01em}
.mp .covbx-l{font-family:var(--sa);font-size:13px;font-weight:600;color:var(--d);line-height:1.3;letter-spacing:.2px}
@media (max-width:767px){.mp .covbox{grid-template-columns:1fr;gap:10px}.mp .covbx{min-height:80px;padding:16px 18px;flex-direction:row;gap:14px}}
.mp .foot{position:absolute;bottom:28px;left:0;right:0;text-align:center}
.mp .cov-name{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(40px,5.5vw,72px);color:var(--d);line-height:1.04;letter-spacing:-.01em;margin:8px auto 2px;max-width:14ch}
.mp .cov-name .ac{color:var(--c)}
.mp .cov-grace-logo{width:100%;max-width:clamp(300px,52vw,560px);height:auto;display:block}
.mp .cov-grace-wrap{display:inline-flex;align-items:center;justify-content:center;margin:16px auto 2px;padding:clamp(26px,3.4vw,38px) clamp(34px,4.5vw,56px);background:linear-gradient(135deg,rgba(255,255,255,.62) 0%,rgba(235,227,210,.4) 100%);border:1px solid rgba(42,114,176,.14);border-radius:22px;box-shadow:0 4px 24px rgba(11,19,32,.05)}
.mp .cov-name-plate{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(34px,4.6vw,58px);color:var(--d);line-height:1.08;letter-spacing:-.01em;text-align:center}
.mp .cov-name-plate .ac{color:var(--c)}

/* Spend bars (problem slide) */
.mp .spend{display:grid;gap:8px;max-width:680px}
.mp .spend .row{display:grid;grid-template-columns:240px 1fr 60px;gap:14px;align-items:center}
.mp .spend .lbl2{font-family:var(--sa);font-size:12px;text-align:right}
.mp .spend .bar{height:22px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden}
.mp .spend .bar>div{height:100%;border-radius:4px}
.mp .spend .val{font-family:var(--mo);font-size:11px;text-transform:uppercase}
.mp .why-hero{display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:780px}
.mp .why-stat{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:28px 30px}
.mp .why-stat.hot{background:linear-gradient(135deg,#41B8CA 0%,#2E97A8 100%);border:1px solid rgba(65,184,202,.5);box-shadow:0 10px 40px rgba(65,184,202,.22),inset 0 1px 0 rgba(255,255,255,.18);position:relative;overflow:hidden}
.mp .why-stat.hot::before{content:"";position:absolute;top:-40%;right:-20%;width:200px;height:200px;background:radial-gradient(circle,rgba(255,255,255,.18) 0%,transparent 70%);pointer-events:none}
.mp .why-stat.hot .why-n{color:#04070D;position:relative;z-index:1}
.mp .why-stat.hot .why-x{color:#04070D;opacity:.7}
.mp .why-stat.hot .why-l{color:#04222A;font-weight:600;position:relative;z-index:1}
.mp .why-n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(44px,5.2vw,64px);color:var(--c);line-height:1;letter-spacing:-.02em}
.mp .why-x{font-family:var(--sa);font-style:normal;font-size:.5em;font-weight:500;margin-left:2px;letter-spacing:0;color:var(--c);opacity:.85}
.mp .why-l{font-family:var(--sa);font-size:13.5px;color:var(--ulg);line-height:1.5;margin-top:14px}
@media (max-width:767px){.mp .why-hero{grid-template-columns:1fr}.mp .spend .row{grid-template-columns:120px 1fr 48px;gap:8px}.mp .spend .lbl2{font-size:10.5px;line-height:1.3}}

/* Objections slide (NEW slide 03) */
.mp .obj-lead{background:var(--gr);border-radius:20px;padding:clamp(30px,4vw,46px) clamp(28px,4vw,50px);margin:8px 0 30px;position:relative;overflow:hidden}
.mp .obj-lead::before{content:"";position:absolute;top:0;right:0;width:340px;height:340px;background:radial-gradient(circle at top right,rgba(65,184,202,.18) 0%,transparent 65%);pointer-events:none}
.mp .obj-lead .eyebrow{font-family:var(--mo);font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-vivid);font-weight:500;margin-bottom:16px;position:relative;z-index:1}
.mp .obj-lead p{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(24px,3vw,40px);color:var(--w);line-height:1.22;letter-spacing:-.01em;margin:0;position:relative;z-index:1;max-width:940px}
.mp .obj-lead p .ac{color:var(--c-vivid)}
.mp .obj-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;grid-auto-rows:1fr}
.mp .obj-grid>.r{height:100%}
.mp .obj-grid>.r>*{height:100%}
.mp .obj-card{background:var(--kb);border:1px solid rgba(42,114,176,.14);border-top:2px solid var(--c);border-radius:16px;padding:24px 26px;display:flex;flex-direction:column}
.mp .obj-card .oq{font-family:var(--sa);font-size:13px;font-weight:600;color:var(--c);line-height:1.4;margin-bottom:10px;font-style:italic}
.mp .obj-card h3{font-family:var(--se);font-style:italic;font-weight:400;font-size:20px;color:var(--d);line-height:1.2;margin:0 0 8px}
.mp .obj-card p{font-family:var(--sa);font-size:13px;color:var(--gy);line-height:1.6;margin:0}
.mp .obj-card p strong{color:var(--d);font-weight:600}
@media (max-width:1023px){.mp .obj-grid{grid-template-columns:1fr 1fr}}
@media (max-width:767px){.mp .obj-grid{grid-template-columns:1fr}}

/* When-was-the-last-time challenge rows */
.mp .lt-sec{margin-top:36px}
.mp .lt-row{display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center;background:#fff;border:1px solid rgba(0,0,0,.06);border-left:4px solid var(--c);border-radius:14px;padding:22px 26px;margin-bottom:12px}
.mp .lt-q{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(18px,2.1vw,23px);color:var(--d);line-height:1.25}
.mp .lt-a{display:flex;flex-direction:column;align-items:flex-end;text-align:right;flex-shrink:0}
.mp .lt-a .brand{font-family:var(--mo);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--c);font-weight:600;margin-bottom:4px}
.mp .lt-a .resp{font-family:var(--sa);font-size:13.5px;font-weight:600;color:var(--d);line-height:1.35;max-width:280px}
@media (max-width:767px){.mp .lt-row{grid-template-columns:1fr;gap:12px}.mp .lt-a{align-items:flex-start;text-align:left}.mp .lt-a .resp{max-width:none}}

/* Two programs cards */
.mp .tp-card{background:var(--kb);border:1px solid rgba(0,0,0,.04);border-top:2px solid var(--c);border-radius:18px;padding:30px 32px;display:flex;flex-direction:column;height:100%}
.mp .tp-tag{display:flex;align-items:baseline;gap:12px;margin-bottom:6px}
.mp .tp-num{font-family:var(--se);font-style:italic;font-weight:400;font-size:32px;color:var(--c);line-height:1}
.mp .tp-kind{font-family:var(--mo);font-size:11px;font-weight:600;letter-spacing:2px;color:var(--c);text-transform:uppercase}
.mp .tp-card h3{font-family:var(--se);font-style:italic;font-weight:400;font-size:26px;color:var(--d);line-height:1.1;margin:6px 0 12px}
.mp .tp-desc{font-family:var(--sa);font-size:14px;color:var(--gy);line-height:1.6;margin-bottom:18px}
.mp .tp-list{list-style:none;padding:0;margin:0 0 20px;display:flex;flex-direction:column;gap:10px}
.mp .tp-list li{display:flex;gap:11px;align-items:flex-start;font-family:var(--sa);font-size:13.5px;color:var(--gy);line-height:1.5}
.mp .tp-list li svg{flex-shrink:0;margin-top:3px;color:var(--c)}
.mp .tp-foot{margin-top:auto;padding-top:18px;border-top:1px solid rgba(42,114,176,.15);display:flex;align-items:baseline;gap:10px}
.mp .tp-foot .fn{font-family:var(--se);font-style:italic;font-weight:400;font-size:34px;color:var(--c);line-height:1}
.mp .tp-foot .fx{font-family:var(--sa);font-style:normal;font-size:.5em;font-weight:500;margin-left:1px;opacity:.85}
.mp .tp-foot .fl{font-family:var(--mo);font-size:10.5px;color:var(--gy);letter-spacing:1.4px;text-transform:uppercase;font-weight:500;line-height:1.4}

/* FFS revenue stat row */
.mp .ffs-cpt{display:flex;flex-wrap:wrap;gap:8px;margin:6px 0 28px}
.mp .ffs-cpt .cp{font-family:var(--mo);font-size:11px;font-weight:600;letter-spacing:1.5px;color:var(--c);background:var(--cb);border:1px solid rgba(42,114,176,.2);border-radius:8px;padding:7px 13px;text-transform:uppercase}
.mp .ffs-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:0;padding:34px 24px;background:linear-gradient(135deg,rgba(42,114,176,.12) 0%,rgba(42,114,176,.02) 100%);border:1px solid rgba(42,114,176,.25);border-radius:18px}
.mp .ffs-stat{text-align:center;padding:8px 20px;position:relative}
.mp .ffs-stat:not(:last-child)::after{content:"";position:absolute;right:0;top:12%;height:76%;width:1px;background:rgba(42,114,176,.2)}
.mp .ffs-n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(44px,5.6vw,68px);color:var(--c);line-height:1;letter-spacing:-.02em}
.mp .ffs-x{font-family:var(--sa);font-style:normal;font-size:.45em;font-weight:500;letter-spacing:0;color:var(--c);opacity:.85;margin-left:2px}
.mp .ffs-l{font-family:var(--mo);font-size:11px;color:var(--gy);letter-spacing:1.4px;margin-top:16px;text-transform:uppercase;font-weight:500;line-height:1.5;max-width:220px;margin-left:auto;margin-right:auto}
.mp .ffs-note{margin-top:18px;font-family:var(--sa);font-size:13px;color:var(--gy);line-height:1.6;font-style:italic;max-width:760px}
@media (max-width:767px){.mp .ffs-stats{grid-template-columns:1fr;padding:20px 22px}.mp .ffs-stat{padding:18px 0;border-bottom:1px solid rgba(42,114,176,.18)}.mp .ffs-stat:last-child{border-bottom:none}.mp .ffs-stat:not(:last-child)::after{display:none}}

/* VBC pricing + risk */
.mp .prc-hero{background:var(--d);border-radius:20px;padding:clamp(32px,4vw,48px) clamp(28px,4vw,52px);display:grid;grid-template-columns:auto 1fr;gap:clamp(28px,4vw,52px);align-items:center}
.mp .prc-big{text-align:center;flex-shrink:0}
.mp .prc-big .n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(72px,8vw,108px);color:var(--c);line-height:.92}
.mp .prc-big .sub{font-family:var(--sa);font-size:14px;color:var(--w);margin-top:8px;font-weight:500}
.mp .prc-big .u{margin-top:12px;font-family:var(--mo);font-size:11px;color:var(--c);letter-spacing:2.2px;text-transform:uppercase;font-weight:500}
.mp .prc-incl{border-left:1px solid rgba(255,255,255,.12);padding-left:clamp(28px,4vw,52px)}
.mp .prc-incl .hd{font-family:var(--mo);font-size:11px;color:var(--ulg);letter-spacing:2px;text-transform:uppercase;font-weight:500;margin-bottom:16px}
.mp .prc-incl ul{list-style:none;padding:0;margin:0;display:grid;grid-template-columns:1fr 1fr;gap:10px 24px}
.mp .prc-incl li{display:flex;align-items:flex-start;gap:10px;font-family:var(--sa);font-size:13.5px;color:var(--w);line-height:1.45}
.mp .prc-incl li svg{flex-shrink:0;margin-top:3px;color:var(--c)}
@media (max-width:767px){.mp .prc-hero{grid-template-columns:1fr;gap:24px}.mp .prc-incl{border-left:none;border-top:1px solid rgba(255,255,255,.12);padding-left:0;padding-top:24px}.mp .prc-incl ul{grid-template-columns:1fr}}

.mp .roi-row{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:14px}
.mp .roi-card{background:var(--kb);border:1px solid rgba(0,0,0,.04);border-top:2px solid var(--c);border-radius:14px;padding:24px 22px;text-align:center}
.mp .roi-n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(40px,5vw,58px);color:var(--c);line-height:1;letter-spacing:-.01em}
.mp .roi-t{font-family:var(--sa);font-size:14px;font-weight:600;color:var(--d);margin-top:10px}
.mp .roi-s{font-family:var(--mo);font-size:10px;color:var(--lg);letter-spacing:1.4px;margin-top:6px;text-transform:uppercase;font-weight:500}
@media (max-width:767px){.mp .roi-row{grid-template-columns:1fr}}

.mp .risk-box{background:rgba(42,114,176,.07);border:1px solid rgba(42,114,176,.22);border-radius:14px;padding:24px 26px;margin-top:24px}
.mp .risk-box .tag{font-family:var(--mo);font-size:10.5px;letter-spacing:2px;color:var(--c);text-transform:uppercase;font-weight:500;margin-bottom:10px;display:block}
.mp .risk-box h4{font-family:var(--se);font-style:italic;font-weight:400;font-size:20px;color:var(--d);margin:0 0 8px;line-height:1.25}
.mp .risk-box p{font-family:var(--sa);font-size:13.5px;color:var(--gy);line-height:1.65;margin:0}
.mp .risk-box p strong{color:var(--d);font-weight:600}

/* Cover program chips */
.mp .cov-progs{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:18px}
.mp .cov-prog{font-family:var(--mo);font-size:13.5px;font-weight:600;letter-spacing:1.8px;text-transform:uppercase;color:var(--c);background:#fff;border:1px solid rgba(42,114,176,.2);border-radius:24px;padding:11px 20px;line-height:1}

/* Programs + Devices slide */
.mp .pg-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px}
.mp .pg-card{background:var(--kb);border:1px solid rgba(0,0,0,.04);border-radius:14px;padding:18px 18px 20px;display:flex;flex-direction:column;gap:8px}
.mp .pg-code{font-family:var(--mo);font-size:13px;font-weight:600;letter-spacing:1.6px;color:var(--c)}
.mp .pg-name{font-family:var(--se);font-style:italic;font-weight:400;font-size:15px;color:var(--d);line-height:1.2}
.mp .pg-desc{font-family:var(--sa);font-size:11.5px;color:var(--gy);line-height:1.45;flex-grow:1}
.mp .pg-cond{margin-top:4px;padding-top:12px;border-top:1px solid rgba(0,0,0,.06);display:flex;flex-direction:column;gap:8px}
.mp .pg-cond-lbl{font-family:var(--mo);font-size:9px;font-weight:500;color:var(--lg);letter-spacing:1.3px;text-transform:uppercase}
.mp .pg-cond-list{display:flex;flex-wrap:wrap;gap:6px}
.mp .pg-cond-pill{font-family:var(--sa);font-size:11px;color:var(--gy);background:var(--cb);border:1px solid rgba(42,114,176,.18);border-radius:8px;padding:4px 9px;font-weight:500}
@media (max-width:1023px){.mp .pg-row{grid-template-columns:repeat(3,1fr)}}
@media (max-width:767px){.mp .pg-row{grid-template-columns:1fr 1fr}}

.mp .kit-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
.mp .kit-grid>.r{display:flex}
.mp .kit-card{width:100%;background:var(--kb);border:1px solid rgba(0,0,0,.04);border-radius:16px;padding:16px 14px 18px;text-align:center;display:flex;flex-direction:column;align-items:stretch;transition:transform .3s ease,box-shadow .3s ease}
.mp .kit-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.06)}
.mp .kit-img{width:100%;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;background:#fff;border-radius:12px;border:1px solid rgba(0,0,0,.03);flex-shrink:0;overflow:hidden}
.mp .kit-img img{width:100%;height:100%;object-fit:cover;display:block}
.mp .kit-ph{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,rgba(42,114,176,.08) 0%,rgba(42,114,176,.02) 100%);color:var(--c)}
.mp .kit-ph svg{width:38px;height:38px;opacity:.85}
.mp .kit-ph span{font-family:var(--mo);font-size:9px;font-weight:600;letter-spacing:1.4px;text-transform:uppercase;opacity:.7}
.mp .kit-tag{font-family:var(--mo);font-size:9px;line-height:1;letter-spacing:1.6px;color:var(--c);text-transform:uppercase;font-weight:600;margin-top:16px;height:9px}
.mp .kit-name{font-family:var(--se);font-style:italic;font-weight:400;font-size:15.5px;line-height:1.2;color:var(--d);margin-top:9px}
.mp .kit-fn{font-family:var(--sa);font-size:11px;line-height:1.4;color:var(--gy);margin-top:5px}
@media (max-width:1023px){.mp .kit-grid{grid-template-columns:repeat(3,1fr)}.mp .kit-grid>.r:nth-child(4),.mp .kit-grid>.r:nth-child(5){grid-column:span 1}}
@media (max-width:767px){.mp .kit-grid{grid-template-columns:1fr 1fr;gap:10px}}
.mp .pg-promise{font-family:var(--sa);font-size:13.5px;color:var(--gy);line-height:1.6;max-width:780px;font-style:italic}

/* Participation head-to-head (slide 04) */
.mp .part-vs{display:grid;grid-template-columns:1fr auto 1.5fr;gap:clamp(16px,3vw,40px);align-items:center;background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:18px;padding:clamp(24px,3.5vw,40px) clamp(24px,4vw,48px)}
.mp .part-side{text-align:center}
.mp .part-tag{font-family:var(--mo);font-size:15px;font-weight:600;letter-spacing:1.8px;text-transform:uppercase;margin-bottom:12px}
.mp .part-base .part-tag{color:var(--lg)}
.mp .part-cade .part-tag{color:var(--c)}
.mp .part-n{font-family:var(--se);font-style:italic;font-weight:400;line-height:.9;letter-spacing:-.02em}
.mp .part-base .part-n{font-size:clamp(40px,5vw,60px);color:var(--lg)}
.mp .part-cade .part-n{font-size:clamp(80px,11vw,150px);color:var(--c)}
.mp .part-x{font-family:var(--sa);font-style:normal;font-weight:500;letter-spacing:0;opacity:.85}
.mp .part-base .part-x{font-size:.5em}
.mp .part-cade .part-x{font-size:.4em;color:var(--c)}
.mp .part-l{font-family:var(--sa);font-size:12.5px;color:var(--gy);line-height:1.4;margin-top:14px;font-weight:500}
.mp .part-cade .part-l{font-weight:600}
.mp .part-vs-mark{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(20px,2.4vw,30px);color:var(--lg);opacity:.6}
.mp .part-mult{display:inline-block;margin-top:12px;font-family:var(--mo);font-size:15px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--c);background:var(--cb);border:1px solid rgba(42,114,176,.3);border-radius:20px;padding:9px 18px}
@media (max-width:767px){.mp .part-vs{grid-template-columns:1fr;gap:18px;padding:24px 22px}.mp .part-vs-mark{transform:rotate(90deg)}.mp .part-base{order:1}.mp .part-vs-mark{order:2}.mp .part-cade{order:3}}

/* FFS who-handles-what split (slide 04) */
.mp .hw-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-top:8px;align-items:stretch}
.mp .hw-panel{border-radius:16px;padding:24px 26px;display:flex;flex-direction:column}
.mp .hw-cade{background:var(--d);position:relative;overflow:hidden}
.mp .hw-cade::before{content:"";position:absolute;top:0;right:0;width:240px;height:240px;background:radial-gradient(circle at top right,rgba(65,184,202,.16) 0%,transparent 65%);pointer-events:none}
.mp .hw-rfmg{background:linear-gradient(135deg,rgba(42,114,176,.10) 0%,rgba(42,114,176,.02) 100%);border:1px solid rgba(42,114,176,.25)}
.mp .hw-hd{display:flex;align-items:baseline;gap:12px;margin-bottom:18px;position:relative;z-index:1}
.mp .hw-tag{font-family:var(--mo);font-size:10.5px;font-weight:600;letter-spacing:1.8px;text-transform:uppercase}
.mp .hw-cade .hw-tag{color:var(--c-vivid)}
.mp .hw-rfmg .hw-tag{color:var(--c)}
.mp .hw-hd h4{font-family:var(--se);font-style:italic;font-weight:400;font-size:21px;line-height:1.1;margin:0}
.mp .hw-cade .hw-hd h4{color:var(--w)}
.mp .hw-rfmg .hw-hd h4{color:var(--d)}
.mp .hw-list{list-style:none;padding:0;margin:0;display:grid;gap:11px;position:relative;z-index:1}
.mp .hw-cade .hw-list{grid-template-columns:1fr 1fr;gap:11px 20px}
.mp .hw-list li{display:flex;gap:11px;align-items:flex-start;font-family:var(--sa);font-size:13.5px;line-height:1.45}
.mp .hw-cade .hw-list li{color:var(--w)}
.mp .hw-rfmg .hw-list li{color:var(--gy)}
.mp .hw-rfmg .hw-list li strong{color:var(--d);font-weight:600}
.mp .hw-c{flex-shrink:0;width:20px;height:20px;display:inline-flex;align-items:center;justify-content:center;border-radius:50%;font-size:11px;font-weight:600;line-height:1;margin-top:1px}
.mp .hw-cade .hw-c{background:var(--c-vivid);color:#04070D}
.mp .hw-rfmg .hw-c{background:var(--c);color:#fff}
@media (max-width:1023px){.mp .hw-grid{grid-template-columns:1fr}.mp .hw-cade .hw-list{grid-template-columns:1fr 1fr}}
@media (max-width:767px){.mp .hw-cade .hw-list{grid-template-columns:1fr}}

/* Per-patient scenarios table (slide 07) */
.mp .cp-scen{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:14px;padding:20px 24px;display:flex;flex-direction:column;gap:2px}
.mp .cp-scen-row{display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:12px;padding:11px 0;align-items:center;border-bottom:1px solid rgba(0,0,0,.04);font-family:var(--sa);font-size:13.5px;color:var(--d)}
.mp .cp-scen-row:last-child{border-bottom:none}
.mp .cp-scen-row.cp-scen-head{font-family:var(--mo);font-size:10px;font-weight:600;color:var(--lg);letter-spacing:1.3px;text-transform:uppercase;padding-bottom:8px}
.mp .cp-scen-row.cp-scen-total{background:var(--cb);margin:8px -16px 0;padding:18px 16px;border-radius:10px;border:1px solid rgba(42,114,176,.28);font-weight:700;font-size:16px}
.mp .cp-scen-row.cp-scen-total .lab{font-weight:700}
.mp .cp-scen-row.cp-scen-total .num{font-size:17px;font-weight:700}
.mp .cp-scen-row .lab{font-weight:500}
.mp .cp-scen-row .num{font-family:var(--mo);text-align:right;font-variant-numeric:tabular-nums;font-weight:500}
.mp .cp-scen-row .num.fee{color:var(--c)}
.mp .cp-scen-row.cp-scen-total .num.fee{color:var(--c)}
@media (max-width:767px){.mp .cp-scen-row{grid-template-columns:1.4fr 1fr 1fr;font-size:12px;gap:8px}}

/* CADE Pricing table */
.mp .cp-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.mp .cp-prog{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:14px;padding:20px 22px;display:flex;flex-direction:column;gap:12px}
.mp .cp-prog-h{display:flex;align-items:baseline;gap:12px;padding-bottom:12px;border-bottom:1px solid rgba(0,0,0,.06)}
.mp .cp-prog-code{font-family:var(--mo);font-size:14px;font-weight:600;color:var(--c);letter-spacing:1.8px}
.mp .cp-prog-name{font-family:var(--se);font-style:italic;font-weight:400;font-size:16px;color:var(--d)}
.mp .cp-table{display:flex;flex-direction:column;gap:2px}
.mp .cp-row{display:grid;grid-template-columns:58px 1fr 70px 70px;gap:8px;align-items:center;padding:7px 0;font-family:var(--sa);font-size:12px;color:var(--gy)}
.mp .cp-row.cp-head{font-family:var(--mo);font-size:9.5px;color:var(--lg);font-weight:600;letter-spacing:1.2px;text-transform:uppercase;padding-bottom:8px;border-bottom:1px solid rgba(0,0,0,.04);margin-bottom:2px}
.mp .cp-c1{font-family:var(--mo);font-size:11px;font-weight:500;color:var(--d)}
.mp .cp-c2{font-family:var(--sa);font-size:12px;color:var(--gy);line-height:1.35}
.mp .cp-c4,.mp .cp-c5{font-family:var(--mo);font-size:11.5px;text-align:right;font-variant-numeric:tabular-nums;font-weight:500}
.mp .cp-c4{color:var(--d)}
.mp .cp-c5{color:var(--c);font-weight:600}
.mp .cp-foot{margin-top:18px;font-family:var(--sa);font-size:11.5px;color:var(--lg);font-style:italic;line-height:1.5;max-width:780px}
.mp .cp-callouts{display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:600px;margin-bottom:8px}
.mp .cp-call{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:14px;padding:20px 24px}
.mp .cp-call.hot{background:linear-gradient(135deg,rgba(42,114,176,.10) 0%,rgba(42,114,176,.02) 100%);border-color:rgba(42,114,176,.28)}
.mp .cp-call-n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(32px,4vw,46px);color:var(--d);line-height:1;letter-spacing:-.02em}
.mp .cp-call.hot .cp-call-n{color:var(--c)}
.mp .cp-call-x{font-family:var(--sa);font-style:normal;font-size:.5em;font-weight:500;margin-left:2px;opacity:.85}
.mp .cp-call-l{font-family:var(--sa);font-size:12.5px;color:var(--gy);line-height:1.5;margin-top:8px}
@media (max-width:1023px){.mp .cp-grid{grid-template-columns:1fr}}
@media (max-width:767px){.mp .cp-callouts{grid-template-columns:1fr}.mp .cp-row{grid-template-columns:48px 1fr 58px 58px;font-size:11px;gap:5px}.mp .cp-c2{font-size:10.5px}.mp .cp-c4,.mp .cp-c5{font-size:10px}}

/* Why CADE slide (07) */
.mp .wc-lead{background:var(--d);border-radius:18px;padding:clamp(30px,4vw,44px) clamp(28px,4vw,48px);margin:8px 0 36px;position:relative;overflow:hidden}
.mp .wc-lead::before{content:"";position:absolute;top:0;right:0;width:320px;height:320px;background:radial-gradient(circle at top right,rgba(65,184,202,.16) 0%,transparent 65%);pointer-events:none}
.mp .wc-lead p{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(24px,3vw,38px);color:var(--w);line-height:1.25;letter-spacing:-.01em;margin:0;position:relative;z-index:1;max-width:920px}
.mp .wc-lead p .ac{color:var(--c-vivid)}
.mp .wc-lead .sub{font-family:var(--sa);font-style:normal;font-size:15px;color:var(--ulg);line-height:1.6;margin-top:18px;max-width:760px;font-weight:400}
.mp .wc-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-bottom:36px;grid-auto-rows:1fr}
.mp .wc-stats .st{text-align:center;display:flex;flex-direction:column;justify-content:center}
.mp .wc-stats .st .n{font-family:var(--se);font-style:italic;font-size:clamp(36px,4.5vw,52px);color:var(--c);line-height:1;font-weight:400}
.mp .wc-stats .st .l{font-family:var(--mo);font-size:12px;letter-spacing:2.2px;color:var(--lg);text-transform:uppercase;margin-top:12px;font-weight:500}
.mp .wc-diffs{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;grid-auto-rows:1fr}
.mp .wc-diffs>.r{height:100%}
.mp .wc-diffs>.r>*{height:100%}
.mp .diff{padding:22px 24px}
.mp .diff.diff-title{display:flex;align-items:center;justify-content:center;text-align:center;min-height:96px}
.mp .diff.diff-title h3{margin:0;font-size:18px;line-height:1.25}
.mp .diff h3{font-size:17px;color:var(--d);margin-bottom:8px;font-family:var(--se);font-style:italic;font-weight:400}
.mp .diff p{font-size:13px;line-height:1.6}
.mp .team-sec{margin-top:40px}
.mp .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:14px;grid-auto-rows:1fr}
.mp .team-grid>.r{height:100%}
.mp .team-grid>.r>*{height:100%}
.mp .card.tm.lead{grid-column:1/-1;background:linear-gradient(135deg,rgba(42,114,176,.12) 0%,rgba(42,114,176,.04) 100%);border:1px solid rgba(42,114,176,.25)}
.mp .card.tm.lead .av{background:var(--c);color:#fff}
.mp .card.tm.lead .av span{color:#fff}
.mp .card.tm.lead .tt{color:var(--c)}
.mp .card.tm.field{grid-column:1/-1;background:#fff;border:1px solid rgba(0,0,0,.06);padding:24px 28px}
.mp .ft-row{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;padding-bottom:18px;border-bottom:1px solid rgba(0,0,0,.06);margin-bottom:16px}
.mp .ft-person{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px}
.mp .ft-person .av{width:64px;height:64px;border-radius:50%;background:var(--cb);border:2px solid var(--c);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
.mp .ft-person .av img{width:100%;height:100%;object-fit:cover}
.mp .ft-nm{font-family:var(--se);font-style:italic;font-weight:400;font-size:16px;color:var(--d);line-height:1.15}
.mp .ft-tt{font-family:var(--mo);font-size:10px;color:var(--c);letter-spacing:1.3px;text-transform:uppercase;font-weight:600}
.mp .ft-bullets{display:flex;flex-direction:column;gap:6px}
@media (max-width:767px){.mp .ft-row{grid-template-columns:1fr;gap:14px}}
.mp .tm{padding:24px 26px}
.mp .tm .hd{display:flex;gap:16px;align-items:center;margin-bottom:14px}
.mp .av{width:60px;height:60px;border-radius:50%;background:var(--cb);border:2px solid var(--c);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;position:relative}
.mp .av span{font-family:var(--se);font-style:italic;font-weight:400;font-size:26px;color:var(--c)}
.mp .av img{width:100%;height:100%;object-fit:cover;display:block;border-radius:50%}
.mp .tm .nm{font-family:var(--se);font-style:italic;font-weight:400;font-size:20px;color:var(--d);line-height:1.1}
.mp .tm .tt{font-family:var(--sa);font-size:12px;color:var(--lg);margin-top:2px}
.mp .tmi{display:flex;gap:10px;margin-bottom:6px;align-items:flex-start}
.mp .tmi .dash{color:var(--c);flex-shrink:0;line-height:1.6}
.mp .tmi .txt{font-size:13px;color:var(--gy);line-height:1.6}
.mp .ros-sec{margin-top:32px}
.mp .ros-hd{display:flex;align-items:center;gap:14px;margin-bottom:16px}
.mp .ros-hd h4{font-family:var(--se);font-style:italic;font-weight:400;font-size:20px;color:var(--d);line-height:1;margin:0;flex-shrink:0}
.mp .ros-hd .line{flex:1;height:1px;background:rgba(0,0,0,.08)}
.mp .ros-hd .count{font-family:var(--mo);font-size:11px;color:var(--lg);letter-spacing:1.5px;flex-shrink:0;font-weight:500;text-transform:uppercase}
.mp .ros-grid{display:grid;gap:12px}
.mp .ros-grid.cs{grid-template-columns:repeat(2,minmax(0,1fr));max-width:440px}
.mp .ros-grid.ct{grid-template-columns:repeat(4,1fr)}
.mp .roster{display:flex;flex-direction:column;align-items:center;text-align:center;padding:24px 14px;background:var(--kb);border:1px solid rgba(0,0,0,.04);border-radius:14px}
.mp .roster .av{width:72px;height:72px;margin:0 0 14px}
.mp .roster .av span{font-size:26px}
.mp .roster .nm{font-family:var(--se);font-style:italic;font-weight:400;font-size:16px;color:var(--d);line-height:1.2}
.mp .roster .tt{font-family:var(--mo);font-size:10.5px;color:var(--lg);margin-top:7px;letter-spacing:1.5px;text-transform:uppercase;font-weight:500}
@media (max-width:1023px){.mp .wc-stats{grid-template-columns:repeat(3,1fr);gap:20px}.mp .wc-diffs{grid-template-columns:repeat(2,1fr)}.mp .team-grid{grid-template-columns:1fr}.mp .ros-grid.ct{grid-template-columns:repeat(3,1fr)}}
@media (max-width:767px){.mp .wc-stats{grid-template-columns:repeat(3,1fr);gap:14px}.mp .wc-diffs{grid-template-columns:1fr}.mp .ros-grid.cs{grid-template-columns:repeat(2,1fr);max-width:none}.mp .ros-grid.ct{grid-template-columns:repeat(2,1fr)}}

/* Philosophy / why-now slide */
.mp .phil-lead{background:var(--gr);border-radius:20px;padding:clamp(30px,4vw,46px) clamp(28px,4vw,50px);margin:8px 0 30px;position:relative;overflow:hidden}
.mp .phil-lead::before{content:"";position:absolute;top:0;right:0;width:340px;height:340px;background:radial-gradient(circle at top right,rgba(65,184,202,.18) 0%,transparent 65%);pointer-events:none}
.mp .phil-lead .eyebrow{font-family:var(--mo);font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-vivid);font-weight:500;margin-bottom:16px;position:relative;z-index:1}
.mp .phil-lead p{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(24px,3vw,40px);color:var(--w);line-height:1.22;letter-spacing:-.01em;margin:0;position:relative;z-index:1;max-width:940px}
.mp .phil-lead p .ac{color:var(--c-vivid)}
.mp .phil-lead .sub{font-family:var(--sa);font-style:normal;font-size:15px;color:var(--ulg);line-height:1.65;margin-top:18px;max-width:780px;font-weight:400;position:relative;z-index:1}
.mp .phil-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;grid-auto-rows:1fr}
.mp .phil-grid>.r{height:100%}
.mp .phil-grid>.r>*{height:100%}
.mp .phil-card{background:var(--kb);border:1px solid rgba(0,0,0,.04);border-top:2px solid var(--c);border-radius:16px;padding:24px 26px;display:flex;flex-direction:column}
.mp .phil-card .pc-k{font-family:var(--mo);font-size:10px;font-weight:600;letter-spacing:1.6px;text-transform:uppercase;color:var(--c);margin-bottom:10px}
.mp .phil-card h3{font-family:var(--se);font-style:italic;font-weight:400;font-size:24px;color:var(--d);line-height:1.16;margin:0 0 8px}
.mp .phil-card p{font-family:var(--sa);font-size:12.5px;color:var(--gy);line-height:1.55;margin:0}
.mp .phil-card p strong{color:var(--d);font-weight:600}
.mp .phil-card.wide{grid-column:span 3}
.mp .phil-river{display:grid;grid-template-columns:1fr auto 1fr;gap:clamp(14px,2.5vw,32px);align-items:stretch}
.mp .river-side{display:flex;flex-direction:column;justify-content:center}
.mp .river-tag{font-family:var(--mo);font-size:10px;font-weight:600;letter-spacing:1.6px;text-transform:uppercase;margin-bottom:8px}
.mp .river-up .river-tag{color:var(--c)}
.mp .river-down .river-tag{color:var(--lg)}
.mp .river-h{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(18px,2vw,23px);line-height:1.2;margin:0 0 6px}
.mp .river-up .river-h{color:var(--d)}
.mp .river-down .river-h{color:var(--gy)}
.mp .river-side p{font-family:var(--sa);font-size:12.5px;color:var(--gy);line-height:1.55;margin:0}
.mp .river-arrow{display:flex;align-items:center;justify-content:center;font-family:var(--se);font-style:italic;font-size:26px;color:var(--c);opacity:.5}
@media (max-width:1023px){.mp .phil-grid{grid-template-columns:repeat(2,1fr)}.mp .phil-card.wide{grid-column:span 2}}
@media (max-width:767px){.mp .phil-grid{grid-template-columns:1fr}.mp .phil-card.wide{grid-column:auto}.mp .phil-river{grid-template-columns:1fr;gap:14px}.mp .river-arrow{transform:rotate(90deg)}}

/* Time-back slide */
.mp .tb-hero{display:grid;grid-template-columns:1fr 1fr;gap:14px;align-items:stretch;margin-top:8px}
.mp .tb-quote{background:var(--gr);border-radius:20px;padding:clamp(30px,4vw,46px);position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center}
.mp .tb-quote::before{content:"";position:absolute;bottom:-30%;left:-10%;width:300px;height:300px;background:radial-gradient(circle,rgba(65,184,202,.16) 0%,transparent 65%);pointer-events:none}
.mp .tb-quote .eyebrow{font-family:var(--mo);font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--c-vivid);font-weight:500;margin-bottom:16px;position:relative;z-index:1}
.mp .tb-quote p{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(22px,2.6vw,32px);color:var(--w);line-height:1.25;margin:0;position:relative;z-index:1}
.mp .tb-quote p .ac{color:var(--c-vivid)}
.mp .tb-stat-col{display:grid;grid-template-rows:1fr 1fr;gap:14px}
.mp .tb-stat{background:var(--kb);border:1px solid rgba(0,0,0,.04);border-top:2px solid var(--c);border-radius:16px;padding:24px 28px;display:flex;flex-direction:column;justify-content:center}
.mp .tb-stat .n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(40px,5vw,58px);color:var(--c);line-height:1;letter-spacing:-.02em}
.mp .tb-stat .n .x{font-family:var(--sa);font-style:normal;font-size:.42em;font-weight:500;margin-left:2px;opacity:.85}
.mp .tb-stat .l{font-family:var(--sa);font-size:13.5px;color:var(--gy);line-height:1.5;margin-top:10px}
.mp .tb-stat .l strong{color:var(--d);font-weight:600}
.mp .tb-row{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:14px;grid-auto-rows:1fr}
.mp .tb-row>.r{height:100%}
.mp .tb-row>.r>*{height:100%}
.mp .tb-card{background:#fff;border:1px solid rgba(0,0,0,.06);border-radius:16px;padding:24px 26px;display:flex;flex-direction:column}
.mp .tb-card .ic{width:42px;height:42px;border-radius:11px;background:var(--cb);display:flex;align-items:center;justify-content:center;margin-bottom:14px;flex-shrink:0}
.mp .tb-card .ic svg{width:21px;height:21px;color:var(--c)}
.mp .tb-card h3{font-family:var(--se);font-style:italic;font-weight:400;font-size:19px;color:var(--d);line-height:1.18;margin:0 0 8px}
.mp .tb-card p{font-family:var(--sa);font-size:13.5px;color:var(--gy);line-height:1.6;margin:0}
/* Q&A pairs */
.mp .tb-qa-wrap{display:flex;flex-direction:column;gap:14px;margin-top:8px}
.mp .tb-qa{display:grid;grid-template-columns:1fr 1fr;gap:14px;align-items:stretch}
.mp .tb-q{background:var(--kb);border:1px solid rgba(42,114,176,.14);border-radius:16px;padding:clamp(26px,3vw,34px);display:flex;flex-direction:column;justify-content:center}
.mp .tb-q .ql{font-family:var(--sa);font-size:22px;letter-spacing:0;text-transform:none;color:var(--c);font-weight:600;line-height:1.4;margin-bottom:0}
.mp .tb-q p{font-family:var(--sa);font-size:22px;font-weight:600;color:var(--c);line-height:1.4;margin:0}
.mp .tb-a{background:var(--gr);border:none;border-radius:16px;padding:clamp(26px,3vw,34px);display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden}
.mp .tb-a::before{content:"";position:absolute;bottom:-32%;right:-10%;width:220px;height:220px;background:radial-gradient(circle,rgba(65,184,202,.14) 0%,transparent 65%);pointer-events:none}
.mp .tb-a .al{font-family:var(--mo);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--c-vivid);font-weight:600;margin-bottom:10px;position:relative;z-index:1}
.mp .tb-a p{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(24px,3vw,34px);color:var(--w);line-height:1.12;margin:0;letter-spacing:-.01em;position:relative;z-index:1}
.mp .tb-a p .ac{color:var(--c-vivid)}
@media (max-width:767px){.mp .tb-qa{grid-template-columns:1fr;gap:10px}}
/* Pull-line cards */
.mp .tb-pull{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
.mp .tb-pull-card{background:var(--kb);border:1px solid rgba(42,114,176,.14);border-left-width:4px;border-radius:14px;padding:clamp(24px,3vw,30px);display:flex;flex-direction:column;justify-content:center}
.mp .tb-pull-load{border-left-color:var(--c)}
.mp .tb-pull-love{border-left-color:var(--c-vivid)}
.mp .tb-pull-card .pl{font-family:var(--mo);font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:600;margin-bottom:10px;color:var(--c)}
.mp .tb-pull-card p{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(19px,2.1vw,24px);line-height:1.2;color:var(--d);margin:0}
.mp .tb-pull-card p strong{font-style:normal;font-weight:600}
@media (max-width:767px){.mp .tb-pull{grid-template-columns:1fr}}
@media (max-width:1023px){.mp .tb-hero{grid-template-columns:1fr}.mp .tb-row{grid-template-columns:1fr}}
@media (max-width:767px){.mp .tb-stat-col{grid-template-rows:auto auto}}

/* Break slide */
.mp .brk{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:clamp(80px,10vh,140px) clamp(24px,5vw,80px);position:relative}
.mp .brk .wrap{align-items:center;max-width:900px}
.mp .brk .prog{font-family:var(--mo);font-size:15px;letter-spacing:5px;color:var(--c);text-transform:uppercase;font-weight:500;margin-bottom:28px}
.mp .brk h2{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(56px,9vw,120px);color:var(--d);line-height:.95;letter-spacing:-.02em;margin:0}
.mp .brk h2 .ac{color:var(--c)}
.mp .brk .sub{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(20px,2.2vw,28px);color:var(--gy);line-height:1.4;margin-top:28px;max-width:620px}

/* Close bento */
.mp .bento{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:minmax(140px,auto);gap:14px;margin-top:18px}
.mp .bc{background:var(--kb);border:1px solid rgba(0,0,0,.04);border-radius:20px;padding:26px 28px;display:flex;flex-direction:column;justify-content:center;overflow:hidden;position:relative}
.mp .bc .pre{font-family:var(--mo);font-size:11px;color:var(--lg);letter-spacing:2px;text-transform:uppercase;font-weight:500;margin-bottom:8px}
.mp .bc .n{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(44px,5.5vw,68px);color:var(--c);line-height:1;letter-spacing:-.02em}
.mp .bc .n .plus{font-size:.55em;vertical-align:top;margin-left:2px;opacity:.85}
.mp .bc .n .x{color:var(--c);margin-left:2px;font-size:.65em;vertical-align:super}
.mp .bc .l{font-family:var(--sa);font-size:14px;font-weight:600;color:var(--d);margin-top:12px;line-height:1.3}
.mp .bc .s{font-family:var(--sa);font-size:12.5px;color:var(--gy);margin-top:6px;line-height:1.5}
.mp .bc.hero{grid-column:span 2;grid-row:span 2;background:#000;background-image:linear-gradient(180deg,rgba(10,10,10,.55) 0%,rgba(10,10,10,.75) 60%,rgba(10,10,10,.9) 100%),url('https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/96cbecff-e1f8-4e83-7579-bc75cf7a9200/public');background-size:cover;background-position:center;background-repeat:no-repeat;text-align:center;align-items:center;justify-content:center;padding:34px 30px;position:relative}
.mp .bc.hero::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 0%,rgba(10,10,10,.35) 100%);pointer-events:none;border-radius:inherit}
.mp .bc.hero>*{position:relative;z-index:1}
.mp .bc.hero .logo{max-width:180px;margin:0 auto;filter:brightness(0) invert(1);opacity:.96}
.mp .bc.hero .kw{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(26px,3vw,36px);color:var(--w);margin-top:18px;line-height:1.1}
.mp .bc.hero .kw .ac{color:var(--c)}
.mp .bc.hero .tag{font-family:var(--mo);font-size:10.5px;color:var(--ulg);letter-spacing:3px;text-transform:uppercase;margin-top:16px;font-weight:500}
.mp .bc.w2{grid-column:span 2}
.mp .bc.accent{background:var(--cb);border:1px solid rgba(42,114,176,.2)}
.mp .bc.tan{background:linear-gradient(135deg,rgba(201,167,124,.22) 0%,rgba(201,167,124,.07) 100%);border:1px solid rgba(168,124,66,.3)}
.mp .bc.tan .pre{color:var(--c-warm-ink,#A87C42)}
.mp .bc.tan .n{color:var(--c-warm-ink,#A87C42)}
.mp .bc.tan .s{color:var(--gy)}
.mp .bc.accent .pre{color:var(--c)}
.mp .bc.accent .n{color:var(--d)}
.mp .bc.dark{background:var(--d);border:none}
.mp .bc.dark .pre{color:var(--ulg)}
.mp .bc.dark .n{color:var(--c)}
.mp .bc.dark .l{color:var(--w)}
.mp .bc.dark .s{color:var(--ulg)}
.mp .bc.feat .ic{font-family:var(--se);font-style:italic;font-weight:400;font-size:34px;color:var(--c);line-height:1;margin-bottom:10px}
.mp .bc.feat .ft{font-family:var(--se);font-style:italic;font-weight:400;font-size:22px;color:var(--d);line-height:1.15;margin-bottom:6px}

.mp .cta-wrap{margin-top:40px;background:var(--d);border-radius:24px;padding:clamp(36px,5vw,56px) clamp(28px,5vw,64px);display:grid;grid-template-columns:1.3fr 1fr;gap:40px;align-items:center}
.mp .cta-l h2{font-family:var(--se);font-style:italic;font-weight:400;font-size:clamp(30px,4vw,52px);color:var(--w);line-height:1.08;letter-spacing:-.01em;margin:0 0 22px}
.mp .cta-l h2 .ac{color:var(--c)}
.mp .cta-l p{font-family:var(--sa);font-size:15px;color:var(--ulg);line-height:1.6;margin:0 0 22px}
.mp .cta-btn{display:inline-flex;align-items:center;gap:10px;background:var(--c);color:#fff;font-family:var(--sa);font-weight:600;font-size:14px;letter-spacing:.3px;padding:14px 26px;border-radius:40px;text-decoration:none;transition:transform .2s ease,background .2s ease;border:none;cursor:pointer}
.mp .cta-btn:hover{transform:translateY(-2px);background:#1f5a8c}
.mp .cta-btn:focus-visible{outline:2px solid #fff;outline-offset:3px}
.mp .cta-btn svg{width:14px;height:14px;transition:transform .25s ease}
.mp .cta-btn:hover svg{transform:translateX(3px)}
.mp .cta-r{display:flex;flex-direction:column;gap:14px;border-left:1px solid rgba(255,255,255,.12);padding-left:40px}
.mp .cta-r .contact{display:flex;flex-direction:column;gap:2px}
.mp .cta-r .contact .n{font-family:var(--se);font-style:italic;font-weight:400;font-size:18px;color:var(--w)}
.mp .cta-r .contact .t{font-family:var(--mo);font-size:10.5px;color:var(--ulg);letter-spacing:1.5px;text-transform:uppercase;font-weight:500}
.mp .cta-r .contact .e{font-family:var(--sa);font-size:13px;color:var(--c);margin-top:2px;text-decoration:underline;text-decoration-color:rgba(65,184,202,.3)}

/* Tablet */
@media(max-width:1023px){
.mp .wrap{max-width:720px}
.mp .g3{grid-template-columns:1fr}
.mp .bento{grid-template-columns:repeat(2,1fr)}
.mp .bc.hero,.mp .bc.w2{grid-column:span 2}
.mp .bc.hero{grid-row:auto;padding:36px 28px}
.mp .cta-wrap{grid-template-columns:1fr;gap:28px;padding:36px 32px}
.mp .cta-r{border-left:none;border-top:1px solid rgba(255,255,255,.12);padding-left:0;padding-top:28px}
.mp section{padding:clamp(72px,9vh,120px) clamp(20px,5vw,48px)}
}
/* Mobile */
@media(max-width:767px){
.mp{font-size:14.5px}
.mp .lbl,.mp .lbl-c,.mp .lbl-lgc{font-size:12.5px;letter-spacing:2px}
.mp .lbl-cov{font-size:13px;letter-spacing:4.5px}
.mp .lbl-lg{font-size:11px;letter-spacing:2.5px}
.mp .wrap{max-width:100%}
.mp .g2,.mp .g3{grid-template-columns:1fr;gap:14px}
.mp .bento{grid-template-columns:1fr;gap:10px}
.mp .bc,.mp .bc.hero,.mp .bc.w2{grid-column:auto;grid-row:auto;padding:24px 22px}
.mp .bc .n{font-size:48px}
.mp .bc.hero{padding:34px 24px}
.mp .bc.hero .kw{font-size:24px}
.mp .cta-wrap{padding:32px 24px;border-radius:20px}
.mp .cta-r{padding-left:0;padding-top:24px;border-left:none;border-top:1px solid rgba(255,255,255,.12)}
.mp .brk .prog{font-size:12px;letter-spacing:3.5px;margin-bottom:22px}
.mp .brk h2{font-size:clamp(48px,13vw,76px)}
.mp .brk .sub{font-size:18px;margin-top:22px}
.mp .card,.mp .dcard{padding:22px 22px}
.mp .tp-card{padding:24px 22px}
.mp section{padding:clamp(72px,9vh,100px) clamp(18px,5vw,32px)}
.mp .nav .inf{min-width:150px}
.mp .nav .lb{max-width:130px;opacity:1}
.mp .nav .tot{opacity:1}
.mp .covlog{height:38px}
.mp .dv{margin:28px 0}
}
/* NATIVE TIMELINE (slide 02) */
.tl-rail{display:grid;grid-template-columns:repeat(6,1fr);gap:18px;margin-top:26px;position:relative;align-items:stretch}
.tl-rail::before{content:"";position:absolute;top:18px;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--c-vivid),var(--c));opacity:.55}
.tl-col{display:flex;flex-direction:column;align-items:center;position:relative}
.tl-node{width:38px;height:38px;border-radius:50%;background:var(--bg);border:2px solid var(--c-vivid);display:flex;align-items:center;justify-content:center;position:relative;z-index:2;margin-bottom:8px}
.tl-node span{font-family:var(--mo);font-weight:700;font-size:14px;color:var(--c)}
.tl-node::after{content:"";position:absolute;top:100%;left:50%;transform:translateX(-50%);width:1px;height:14px;background:var(--c-vivid);opacity:.5}
.tl-card{background:var(--w);border:1px solid var(--gb);border-radius:16px;padding:20px 16px 0;text-align:center;width:100%;flex:1;display:flex;flex-direction:column;box-shadow:0 14px 34px -22px rgba(11,19,32,.35)}
.tl-icon{width:54px;height:54px;border-radius:50%;background:var(--cb);display:flex;align-items:center;justify-content:center;margin:6px auto 14px}
.tl-icon svg{width:26px;height:26px;color:var(--c)}
.tl-title{font-family:var(--se);font-style:italic;font-weight:500;font-size:18px;line-height:1.15;color:var(--d);margin:0 0 10px}
.tl-body{font-family:var(--sa);font-size:12.5px;line-height:1.5;color:var(--gy);margin:0 0 16px;flex:1}
.tl-tag{display:flex;align-items:center;justify-content:center;gap:7px;border-top:1px solid var(--gb);padding:11px 0;margin:0 -16px}
.tl-tag svg{width:16px;height:16px;color:var(--c);flex:none}
.tl-tag span{font-family:var(--sa);font-size:12px;font-weight:600;color:var(--c)}
.tl-daterow{display:grid;grid-template-columns:repeat(6,1fr);gap:18px;margin-top:16px;padding-top:16px;border-top:1px dashed var(--gh)}
.tl-datecol{text-align:center}
.tl-date-k{font-family:var(--sa);font-size:14px;font-weight:700;color:var(--c)}
.tl-date-sub{font-family:var(--sa);font-size:11.5px;color:var(--gy);line-height:1.4;margin-top:4px}
.tl-date-ex{font-family:var(--se);font-style:italic;font-size:11.5px;color:var(--c-vivid);margin-top:5px}
.tl-foot{display:flex;align-items:center;gap:28px;flex-wrap:wrap;background:var(--w);border:1px solid var(--gb);border-radius:16px;padding:20px 24px;margin-top:30px}
.tl-foot-main{display:flex;align-items:flex-start;gap:14px;flex:1;min-width:280px}
.tl-foot-ico{width:42px;height:42px;border-radius:50%;background:var(--cb);display:flex;align-items:center;justify-content:center;flex:none}
.tl-foot-ico svg{width:22px;height:22px;color:var(--c)}
.tl-foot-h{font-family:var(--sa);font-size:14px;font-weight:700;color:var(--c);margin-bottom:4px}
.tl-foot-p{font-family:var(--sa);font-size:12.5px;color:var(--gy);line-height:1.5}
.tl-foot-badges{display:flex;gap:18px;flex-wrap:wrap}
.tl-badge{display:flex;align-items:center;gap:7px;font-family:var(--sa);font-size:12.5px;font-weight:600;color:var(--gy);white-space:nowrap}
.tl-badge svg{width:16px;height:16px;color:var(--c-vivid);flex:none}
.tl-foot-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:30px;align-items:stretch}
.tl-foot-row .tl-foot{margin-top:0;flex-direction:column;align-items:stretch}
.tl-foot-enroll{gap:0}
.tl-foot-h-center{text-align:center;letter-spacing:1.5px;text-transform:uppercase;font-size:13px}
.tl-foot-sub{font-family:var(--sa);font-size:12.5px;color:var(--gy);text-align:center;margin:6px 0 16px;line-height:1.5}
.tl-enroll-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:14px;align-items:center}
.tl-enroll-card{display:flex;gap:11px;align-items:flex-start}
.tl-enroll-ico{width:36px;height:36px;border-radius:9px;background:var(--cb);display:flex;align-items:center;justify-content:center;flex:none}
.tl-enroll-ico svg{width:19px;height:19px;color:var(--c)}
.tl-enroll-h{font-family:var(--sa);font-size:13px;font-weight:700;color:var(--c);margin-bottom:4px}
.tl-enroll-p{font-family:var(--sa);font-size:11.5px;color:var(--gy);line-height:1.45}
.tl-enroll-or{font-family:var(--mo);font-size:11px;font-weight:700;color:var(--lg);background:var(--gl);border:1px solid var(--gb);border-radius:50%;width:34px;height:34px;display:flex;align-items:center;justify-content:center;flex:none}
@media(max-width:1023px){
  .tl-rail,.tl-daterow{grid-template-columns:repeat(3,1fr);gap:16px 14px}
  .tl-rail::before{display:none}
  .tl-node::after{display:none}
  .tl-daterow{border-top:none;padding-top:0;margin-top:18px}
  .tl-datecol{padding-top:8px;border-top:1px dashed var(--gh)}
  .tl-foot-row{grid-template-columns:1fr;gap:16px}
}
@media(max-width:600px){
  .tl-rail,.tl-daterow{grid-template-columns:repeat(2,1fr);gap:14px 12px}
  .tl-title{font-size:16px}
  .tl-body{font-size:12px}
  .tl-foot{padding:18px;gap:18px}
  .tl-foot-badges{gap:12px 16px}
  .tl-enroll-grid{grid-template-columns:1fr;gap:12px}
  .tl-enroll-or{margin:0 auto}
}
@media(max-width:380px){.tl-rail,.tl-daterow{grid-template-columns:1fr}}
/* ROI CALCULATOR */
.calc{background:linear-gradient(160deg,#0A1626 0%,#14294A 100%);border-radius:22px;padding:clamp(26px,4vw,46px);color:var(--w);box-shadow:0 30px 70px -30px rgba(11,19,32,.5);margin-top:18px}
.calc-head{margin-bottom:30px}
.calc-head .ce{font-family:var(--mo);font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--c-vivid);margin-bottom:12px}
.calc-head h3{font-family:var(--se);font-style:italic;font-weight:500;font-size:clamp(26px,3.4vw,40px);line-height:1.05;color:var(--w);margin:0}
.calc-head h3 .ac{color:var(--c-vivid)}
.calc-head .cd{font-family:var(--sa);font-size:14px;color:var(--ulg);margin-top:12px;max-width:60ch;line-height:1.5}
.calc-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(24px,3.4vw,46px);align-items:start}
.calc-sliders{display:flex;flex-direction:column;gap:24px}
.sl{display:block}
.sl-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px;gap:12px}
.sl-lab{font-family:var(--sa);font-size:13.5px;font-weight:600;color:var(--w);letter-spacing:.01em}
.sl-val{font-family:var(--mo);font-size:18px;font-weight:600;color:var(--c-vivid);white-space:nowrap}
.sl-track{position:relative;padding:2px 0}
.calc input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:5px;border-radius:99px;background:rgba(191,208,228,.22);outline:none;margin:0;cursor:pointer}
.calc input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:20px;height:20px;border-radius:50%;background:var(--c-vivid);border:3px solid #0A1626;box-shadow:0 0 0 1px var(--c-vivid),0 4px 10px rgba(0,0,0,.35);cursor:pointer;transition:transform .12s ease}
.calc input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.12)}
.calc input[type=range]::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--c-vivid);border:3px solid #0A1626;box-shadow:0 0 0 1px var(--c-vivid),0 4px 10px rgba(0,0,0,.35);cursor:pointer}
.calc input[type=range]::-moz-range-track{height:5px;border-radius:99px;background:rgba(191,208,228,.22)}
.sl-marks{position:relative;height:16px;margin-top:7px}
.sl-avg{position:absolute;top:0;transform:translateX(-50%);font-family:var(--mo);font-size:10px;letter-spacing:.04em;color:var(--c-warm);white-space:nowrap;display:flex;flex-direction:column;align-items:center;gap:3px}
.sl-avg::before{content:"";width:1px;height:6px;background:var(--c-warm);opacity:.7}
.sl-avg.below{transform:translateX(-50%)}
.calc-out{background:rgba(255,255,255,.04);border:1px solid rgba(191,208,228,.14);border-radius:16px;padding:26px;display:flex;flex-direction:column;gap:20px;position:sticky;top:90px}
.co-funnel{display:flex;flex-direction:column;gap:9px;padding-bottom:18px;border-bottom:1px solid rgba(191,208,228,.14)}
.co-row{display:flex;justify-content:space-between;align-items:baseline;font-family:var(--sa);font-size:13px;color:var(--ulg)}
.co-row .v{font-family:var(--mo);font-weight:600;color:var(--w);font-size:14px}
.co-row.enr{color:var(--w);font-weight:600}
.co-row.enr .v{color:var(--c-vivid);font-size:16px}
.co-big{display:flex;flex-direction:column;align-items:flex-start;gap:4px}
.co-big .num{align-self:stretch;width:100%}
.co-big .k{font-family:var(--mo);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ulg)}
.co-big .num{font-family:var(--mo);font-weight:700;color:var(--w);line-height:1;font-size:clamp(30px,3.6vw,40px);letter-spacing:-.01em}
.co-big.annual .num{color:var(--c-vivid)}
.co-big .sub{font-family:var(--sa);font-size:12px;color:var(--lg)}
.co-split{font-family:var(--sa);font-size:11.5px;color:var(--lg);line-height:1.5;padding-top:4px;border-top:1px solid rgba(191,208,228,.1)}
.calc-fine{font-family:var(--sa);font-size:11px;color:var(--lg);margin-top:22px;line-height:1.5}
@media(max-width:860px){.calc-grid{grid-template-columns:1fr;gap:30px}.calc-out{position:static}}
@media(max-width:560px){
  .calc{padding:22px 18px;border-radius:18px}
  .calc-head h3{font-size:24px}
  .calc-out{padding:20px 16px}
  .co-big .num{font-size:clamp(26px,8vw,34px);white-space:nowrap;letter-spacing:-.02em}
  .sl-val{font-size:16px}
  .sl-lab{font-size:12.5px}
  .co-row,.co-row .v{font-size:12.5px}
}
@media(max-width:400px){
  .mp .cp-prog{padding:16px 14px}
  .mp .cp-row{grid-template-columns:40px 1fr 50px 50px;gap:4px}
  .mp .cp-c1{font-size:10px}
  .mp .cp-c2{font-size:10px}
  .mp .cp-c5{font-size:9.5px}
}
</style>

<div class="blob"></div>

<nav class="nav" id="mpnav">
<div class="prog-track"><div class="prog-fill" id="mpprog"></div></div>
<button class="ch up" id="mpup" aria-label="Previous section"><svg viewBox="0 0 14 8" fill="none" aria-hidden="true"><path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
<div class="inf" role="status" aria-live="polite" aria-atomic="true"><span class="idx" id="mpidx">01</span><span class="lb" id="mplb">COVER</span><span class="tot" id="mptot">/ 11</span></div>
<button class="ch dn" id="mpdn" aria-label="Next section"><svg viewBox="0 0 14 8" fill="none" aria-hidden="true"><path d="M1 1L7 7L13 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
</nav>

<!-- 01 COVER -->
<section id="mp-cover" class="ctr"><div class="wrap"><div class="r" data-d="0.05"><img src="https://imagedelivery.net/qJvpJU9hpeX3lEcmqZfcwg/ea71bdc8-b2c0-4c20-b8a2-e702a7164900/public" alt="CADE" class="covlog" style="margin-bottom:18px"></div><div class="r" data-d="0.2"><h1 class="h1">Connected Care.<br><span class="ac">Built around you.</span></h1></div><div class="r" data-d="0.4"><div class="dv"></div></div><div class="cov-progs" style="margin-top:24px"><span class="cov-prog">RPM</span><span class="cov-prog">CCM</span><span class="cov-prog">RTM</span><span class="cov-prog">PCM</span><span class="cov-prog">BHM</span></div></div><div class="foot"><span class="lbl lbl-lg">CONFIDENTIAL</span></div></section>

<!-- 02 WHY THIS, WHY NOW -->
<section id="mp-why-now" class="sct"><div class="wrap"><div class="r"><span class="num">01</span></div><div class="r" data-d="0.08"><span class="lbl lbl-c">WHY THIS &middot; WHY NOW</span></div><div class="r" data-d="0.14"><h2 class="h2">Extending your care into the home.<br><span class="ac">Minimal lift.</span></h2></div>

<div class="r" data-d="0.2"><div class="phil-lead"><div class="eyebrow">A New Way of Thinking</div><p>Medicare is shifting its focus from reactive to proactive. <span class="ac">They are putting massive focus and incentive on Connected Care.</span></p><div class="sub">These are a select few of the codes that are actually going up in allowable year over year. CMS designed these programs, rewards them, and is pushing providers hard to adopt them.</div></div></div>

<div class="r" data-d="0.24"><div class="phil-grid">

<div class="r" data-d="0.26"><div class="phil-card"><div class="pc-k">Proactive, Not Reactive</div><h3>Catch it up river</h3><p>Catch a negative trend while it is still a phone call, not a hospital stay.</p></div></div>
<div class="r" data-d="0.30"><div class="phil-card"><div class="pc-k">Up River Or Down</div><h3>Medicare spends either way</h3><p>Medicare pays for the crisis downstream or the prevention up river. The dollars get spent. The question is where.</p></div></div>
<div class="r" data-d="0.34"><div class="phil-card"><div class="pc-k">Medicare-Backed</div><h3>Real focus from CMS</h3><p>This is Medicare-backed reimbursement, and CMS is putting immense weight behind it, actively pushing providers to adopt it.</p></div></div>
<div class="r" data-d="0.38"><div class="phil-card"><div class="pc-k">2026 Rate Increase</div><h3>Revenue moving up</h3><p>A roughly 12% reimbursement increase in 2026, with two new RPM codes that widen the billable population.</p></div></div>
<div class="r" data-d="0.42"><div class="phil-card"><div class="pc-k">Easier Compliance</div><h3>New, simpler codes</h3><p>The newest CMS codes lower the documentation burden and shift the focus back to the work that actually matters.</p></div></div>
<div class="r" data-d="0.46"><div class="phil-card"><div class="pc-k">Patient Experience</div><h3>Real people, no AI</h3><p>No AI calling. No call centers. A real, designated care member reaches your patients every week.</p></div></div>
<div class="r" data-d="0.50"><div class="phil-card"><div class="pc-k">Local</div><h3>Account managers nearby</h3><p>Local account managers who show up in person, in your market, in your time zone.</p></div></div>
<div class="r" data-d="0.54"><div class="phil-card"><div class="pc-k">Zero Logistics</div><h3>We handle the devices</h3><p>We source, configure, and drop-ship every device to the patient's door. No inventory, no setup on your end.</p></div></div>
<div class="r" data-d="0.58"><div class="phil-card"><div class="pc-k">Cellular By Design</div><h3>Data flows to us</h3><p>Data flows through cellular chips built into every device, straight into our system for remote monitoring, where our team watches and escalates.</p></div></div>
<div class="r" data-d="0.62"><div class="phil-card"><div class="pc-k">Your Team, Extended</div><h3>Local clinical staff</h3><p>Local clinical staff assigned to your clinic. 1 staff member per 100 to 150 patients.</p></div></div>
<div class="r" data-d="0.66"><div class="phil-card"><div class="pc-k">The Upside</div><h3>$160 to $300 per patient</h3><p>Done well, the program returns roughly $160 to $300 per enrolled patient per month in practice revenue.</p></div></div>

</div></div>

</div></section>

<!-- 03 TAKING IT OFF YOUR PLATE -->
<section id="mp-offplate" class="sct"><div class="wrap"><div class="r"><span class="num">02</span></div><div class="r" data-d="0.08"><span class="lbl lbl-c">TAKING IT OFF YOUR PLATE</span></div><div class="r" data-d="0.14"><h2 class="h2">We hear the same things.<br><span class="ac">Here is the honest answer.</span></h2></div>

<div class="r" data-d="0.2"><div class="obj-lead"><div class="eyebrow">Straight Talk</div><p>We do not want to hand you one more thing to run. <span class="ac">We want to join your team and carry the load.</span></p></div></div>

<div class="r" data-d="0.24"><div class="obj-grid">
<div class="r" data-d="0.26"><div class="obj-card"><div class="oq">&ldquo;But we are overworked already.&rdquo;</div><h3>That is the point</h3><p>We know. That is exactly why we want to join your team, not hand you one more thing to run.</p></div></div>
<div class="r" data-d="0.30"><div class="obj-card"><div class="oq">&ldquo;But it will cost too much.&rdquo;</div><h3>Net positive by design</h3><p>No upfront cost. Net positive by design. If that is still too much, we honestly are not the right fit.</p></div></div>
<div class="r" data-d="0.34"><div class="obj-card"><div class="oq">&ldquo;But we tried it before and it failed.&rdquo;</div><h3>Tried what, exactly?</h3><p>Connected Care with CADE, or some hands-off &ldquo;remote&rdquo; program that left you to do the work?</p></div></div>
</div></div>

<div class="lt-sec r" data-d="0.4"><span class="lbl lbl-c" style="margin-bottom:14px;display:block">WHEN WAS THE LAST TIME&hellip;</span>
<div class="lt-row"><div class="lt-q">When was the last time you watched vitals at home?</div><div class="lt-a"><span class="brand">CADE</span><span class="resp">We do it all day long.</span></div></div>
<div class="lt-row"><div class="lt-q">When was the last time you called a patient between visits?</div><div class="lt-a"><span class="brand">CADE</span><span class="resp">That is our full time job.</span></div></div>
<div class="lt-row"><div class="lt-q">When was the last time you walked a patient through their insurance and the state programs they qualify for?</div><div class="lt-a"><span class="brand">CADE</span><span class="resp">We make sure they understand it.</span></div></div>
<div class="lt-row"><div class="lt-q">Tired of chasing prior auths?</div><div class="lt-a"><span class="brand">CADE</span><span class="resp">Let us take that load.</span></div></div>
</div>

</div></section>

<!-- 04 TIME BACK / WORKFLOW -->
<section id="mp-timeback" class="sct"><div class="wrap"><div class="r"><span class="num">03</span></div><div class="r" data-d="0.08"><span class="lbl lbl-c">CONNECTED CARE WORKFLOW</span></div><div class="r" data-d="0.14"><h2 class="h2">From enrollment<br><span class="ac">to reimbursement.</span></h2></div><div class="r" data-d="0.2"><p class="intro" style="margin-bottom:8px">CADE&rsquo;s connected care model simplifies every step, so providers can focus on what matters most: better patient outcomes.</p></div><div class="r" data-d="0.26"><div class="tl-rail"><div class="tl-col"><div class="tl-node"><span>01</span></div><div class="tl-card"><div class="tl-icon"><svg viewBox="0 0 24 24" fill="none"><circle cx="9" cy="8" r="3.2" stroke="currentColor" stroke-width="1.5"/><path d="M3.5 19c0-3 2.5-5 5.5-5s5.5 2 5.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="17" cy="9" r="2.4" stroke="currentColor" stroke-width="1.5"/><path d="M16 14.2c2.4.2 4.5 1.8 4.5 4.8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div><h3 class="tl-title">Enroll &amp; Consent</h3><p class="tl-body">Local outreach team identifies eligible patients, secures consent, and coordinates enrollment.</p><div class="tl-tag"><svg viewBox="0 0 24 24" fill="none"><path d="M6 4h3l1.5 4-2 1.5a11 11 0 005 5l1.5-2 4 1.5v3c0 1-.8 1.8-1.8 1.6A15 15 0 014.4 6.8C4.2 5.8 5 5 6 5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg><span>Patient Outreach</span></div></div></div><div class="tl-col"><div class="tl-node"><span>02</span></div><div class="tl-card"><div class="tl-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 2.5v5.5c0 4.5-3 7.7-7 9-4-1.3-7-4.5-7-9V5.5L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><h3 class="tl-title">Verify Insurance &amp; Benefits</h3><p class="tl-body">We verify eligibility and review benefits to confirm coverage and prevent denials.</p><div class="tl-tag"><svg viewBox="0 0 24 24" fill="none"><rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M8 8h8M8 12h8M8 16h5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg><span>Benefits Summary</span></div></div></div><div class="tl-col"><div class="tl-node"><span>03</span></div><div class="tl-card"><div class="tl-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M4 7.5l8 4.5 8-4.5M12 12v9" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg></div><h3 class="tl-title">Device Delivery</h3><p class="tl-body">Cellular devices ship directly to the patient&rsquo;s home with onboarding support.</p><div class="tl-tag"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M4 7.5l8 4.5 8-4.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg><span>Device Shipped</span></div></div></div><div class="tl-col"><div class="tl-node"><span>04</span></div><div class="tl-card"><div class="tl-icon"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 11h3l1.5-3 2 5 1.5-2.5h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><h3 class="tl-title">Monitor &amp; Document</h3><p class="tl-body">Licensed clinical staff review readings, engage patients, and generate CPT-ready documentation.</p><div class="tl-tag"><svg viewBox="0 0 24 24" fill="none"><path d="M5 19V10M10 19V5M15 19v-6M20 19V8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg><span>Monthly Monitoring</span></div></div></div><div class="tl-col"><div class="tl-node"><span>05</span></div><div class="tl-card"><div class="tl-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M7 3h7l4 4v14H7V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 3v4h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12.5 16V10M10 12.5l2.5-2.5 2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><h3 class="tl-title">Billing Submission</h3><p class="tl-body">On the 1st of the month, CADE sends prior month&rsquo;s data and documentation to the practice.</p><div class="tl-tag"><svg viewBox="0 0 24 24" fill="none"><path d="M12 20V8M7 12l5-5 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 4h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg><span>Data Sent (1st)</span></div></div></div><div class="tl-col"><div class="tl-node"><span>06</span></div><div class="tl-card"><div class="tl-icon"><svg viewBox="0 0 24 24" fill="none"><path d="M7 3h7l4 4v14H7V3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 3v4h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12.5 17v-1m0-6v-1m1.8 2.2c0-.8-.8-1.2-1.8-1.2s-1.8.5-1.8 1.3.9 1.1 1.8 1.2 1.8.5 1.8 1.3-.8 1.2-1.8 1.2-1.8-.5-1.8-1.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></div><h3 class="tl-title">Invoice Net 60</h3><p class="tl-body">CADE invoices the practice for the service fee. Payment due 60 days from invoice date.</p><div class="tl-tag"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.4"/><path d="M12 17v-1m0-8V7m1.8 3c0-.8-.8-1.2-1.8-1.2s-1.8.5-1.8 1.3.9 1.1 1.8 1.2 1.8.5 1.8 1.3-.8 1.2-1.8 1.2-1.8-.5-1.8-1.2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg><span>Invoice Issued</span></div></div></div></div><div class="tl-daterow"><div class="tl-datecol"><div class="tl-date-k">Day 1</div><div class="tl-date-sub">Patient consents to participate.</div></div><div class="tl-datecol"><div class="tl-date-k">Day 1&ndash;2</div><div class="tl-date-sub">Eligibility verified and benefits confirmed.</div></div><div class="tl-datecol"><div class="tl-date-k">Day 3&ndash;7</div><div class="tl-date-sub">Device shipped and patient onboarded.</div></div><div class="tl-datecol"><div class="tl-date-k">Monthly Period</div><div class="tl-date-sub">Continuous monitoring throughout the month.</div><div class="tl-date-ex">Example: May 1&ndash;May 31</div></div><div class="tl-datecol"><div class="tl-date-k">First of Month</div><div class="tl-date-ex">Example: June 1 (sends May data)</div></div><div class="tl-datecol"><div class="tl-date-k">Net 60 Terms</div><div class="tl-date-sub">Due 60 days from the date the data is sent.</div><div class="tl-date-ex">Example: Due July 31</div></div></div></div><div class="r" data-d="0.42"><div class="tl-foot-row"><div class="tl-foot tl-foot-enroll"><div class="tl-foot-h tl-foot-h-center">ENROLLMENT OPTIONS</div><div class="tl-foot-sub">Practices can enroll patients internally or leverage CADE&rsquo;s dedicated outreach team.</div><div class="tl-enroll-grid"><div class="tl-enroll-card"><div class="tl-enroll-ico"><svg viewBox="0 0 24 24" fill="none"><path d="M4 10l8-5 8 5M6 9v9h12V9M9 18v-4h6v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div><div class="tl-enroll-h">Practice-Led Enrollment</div><div class="tl-enroll-p">Office staff identifies eligible patients, explains the program, obtains consent, and enrolls patients directly.</div></div></div><div class="tl-enroll-or">OR</div><div class="tl-enroll-card"><div class="tl-enroll-ico"><svg viewBox="0 0 24 24" fill="none"><path d="M6 4h3l1.5 4-2 1.5a11 11 0 005 5l1.5-2 4 1.5v3c0 1-.8 1.8-1.8 1.6A15 15 0 014.4 6.8C4.2 5.8 5 5 6 5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg></div><div><div class="tl-enroll-h">CADE Outreach Enrollment</div><div class="tl-enroll-p">CADE&rsquo;s dedicated outreach team contacts eligible patients on behalf of the practice using practice-branded messaging and phone lines.</div></div></div></div></div><div class="tl-foot"><div class="tl-foot-main"><div class="tl-foot-ico"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l7 2.5v5.5c0 4.5-3 7.7-7 9-4-1.3-7-4.5-7-9V5.5L12 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div><div class="tl-foot-h">Secure. Compliant. Connected.</div><div class="tl-foot-p">CADE uses secure technology and documented processes to protect patient data and ensure compliance with HIPAA and CMS requirements.</div></div></div><div class="tl-foot-badges"><span class="tl-badge"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M8.5 12l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>HIPAA Compliant</span><span class="tl-badge"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M8.5 12l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>CMS Aligned</span><span class="tl-badge"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M8.5 12l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Data Secure</span><span class="tl-badge"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M8.5 12l2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Audit Ready</span></div></div></div></div></section>

<!-- 05 PROGRAMS + DEVICES -->
<section id="mp-kit" class="sct"><div class="wrap"><div class="r"><span class="num">04</span></div><div class="r" data-d="0.08"><span class="lbl lbl-c">THE PROGRAMS &amp; THE KIT</span></div><div class="r" data-d="0.14"><h2 class="h2">Five programs.<br><span class="ac">FDA-cleared devices, shipped direct.</span></h2></div>

<div class="r" data-d="0.22" style="margin-top:8px"><div class="pg-row">
<div class="pg-card"><div class="pg-code">RPM</div><div class="pg-name">Remote Patient Monitoring</div><div class="pg-desc">Cellular devices in the home. Daily physiologic data, watched and escalated.</div><div class="pg-cond"><span class="pg-cond-lbl">Top Conditions</span><div class="pg-cond-list"><span class="pg-cond-pill">Hypertension</span><span class="pg-cond-pill">Diabetes</span></div></div></div>
<div class="pg-card"><div class="pg-code">CCM</div><div class="pg-name">Chronic Care Management</div><div class="pg-desc">Monthly clinical engagement for two or more chronic conditions.</div><div class="pg-cond"><span class="pg-cond-lbl">Top Conditions</span><div class="pg-cond-list"><span class="pg-cond-pill">Diabetes</span><span class="pg-cond-pill">Heart Failure</span></div></div></div>
<div class="pg-card"><div class="pg-code">RTM</div><div class="pg-name">Remote Therapeutic Monitoring</div><div class="pg-desc">Therapy adherence and behavior tracking for non-physiologic conditions.</div><div class="pg-cond"><span class="pg-cond-lbl">Top Conditions</span><div class="pg-cond-list"><span class="pg-cond-pill">Musculoskeletal</span><span class="pg-cond-pill">Asthma / COPD</span></div></div></div>
<div class="pg-card"><div class="pg-code">PCM</div><div class="pg-name">Principal Care Management</div><div class="pg-desc">A single high-acuity condition with a dedicated monthly care plan.</div><div class="pg-cond"><span class="pg-cond-lbl">Top Conditions</span><div class="pg-cond-list"><span class="pg-cond-pill">Severe COPD</span><span class="pg-cond-pill">CHF</span></div></div></div>
<div class="pg-card"><div class="pg-code">BHM</div><div class="pg-name">Behavioral Health Management</div><div class="pg-desc">Integrated behavioral health monitoring, alongside primary care.</div><div class="pg-cond"><span class="pg-cond-lbl">Top Conditions</span><div class="pg-cond-list"><span class="pg-cond-pill">Depression</span><span class="pg-cond-pill">Anxiety</span></div></div></div>
</div></div>

<div class="r" data-d="0.36" style="margin-top:30px"><span class="lbl lbl-c" style="margin-bottom:14px;display:block">THE KIT &middot; CONDITION-MATCHED, ZERO SETUP</span><div class="kit-grid">
<div class="r" data-d="0.38"><div class="kit-card"><div class="kit-img"><img src="https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/2912d069-31c8-4f93-f2dc-3732a098f800/public" alt="BodyTrace Cuff" loading="lazy"></div><div class="kit-tag">RPM</div><div class="kit-name">BodyTrace Cuff</div><div class="kit-fn">Cellular BP monitor</div></div></div>
<div class="r" data-d="0.42"><div class="kit-card"><div class="kit-img"><img src="https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/36970769-d930-482a-3cd1-63c2f405bd00/public" alt="BodyTrace Scale" loading="lazy"></div><div class="kit-tag">RPM</div><div class="kit-name">BodyTrace Scale</div><div class="kit-fn">Cellular weight scale</div></div></div>
<div class="r" data-d="0.46"><div class="kit-card"><div class="kit-img"><img src="data:image/jpeg;base64," alt="Telli 4G Pulse Ox" loading="lazy"></div><div class="kit-tag">RPM</div><div class="kit-name">Telli 4G Pulse Ox</div><div class="kit-fn">Cellular SpO&#8322; monitor</div></div></div>
<div class="r" data-d="0.5"><div class="kit-card"><div class="kit-img"><img src="https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/6d57962b-619b-4a33-b39e-725ba38e2d00/public" alt="Tenovi Pillbox" loading="lazy"></div><div class="kit-tag">ADHERENCE</div><div class="kit-name">Tenovi Pillbox</div><div class="kit-fn">Medication tracker</div></div></div>
<div class="r" data-d="0.54"><div class="kit-card"><div class="kit-img"><img src="https://imagedelivery.net/IImSqGpRtERo2xUi3EGF4Q/4a02accb-1123-4801-6bc5-e0525746bc00/public" alt="Continuous Glucose Monitor" loading="lazy"></div><div class="kit-tag">CGM</div><div class="kit-name">CGM</div><div class="kit-fn">Dexcom G7 &middot; Libre 3 Plus</div></div></div>
</div></div>

<div class="r" data-d="0.6" style="margin-top:18px"><p class="pg-promise">All hardware is FDA-cleared, cellular-enabled, and zero-setup. No WiFi, no app, no technical support calls. Additional devices (sleep monitors, digital inhalers, peak flow meters, thermometers) available on request.</p></div>

</div></section>

<!-- 06 THE PROBLEM -->
<section id="mp-why" class="gbg"><div class="wrap"><div class="r"><span class="num dk">05</span></div><div class="r" data-d="0.08"><span class="lbl lbl-lgc">THE PROBLEM</span></div><div class="r" data-d="0.14"><h2 class="h2 h2w">Your sickest patients. Your least-watched <span class="ac">panel.</span></h2></div><div class="r" data-d="0.3"><span class="lbl lbl-c" style="margin-bottom:16px">U.S. HEALTH SPENDING BY DISEASE CATEGORY</span><div class="spend" id="mp-spend"></div><div style="font-size:12px;color:var(--ulg);margin-top:14px;max-width:680px;font-family:var(--mo);letter-spacing:.5px">Source: <a href="https://hcup-us.ahrq.gov/reports/statbriefs/sb304-readmissions-2016-2020.jsp" target="_blank" rel="noopener" class="src-link" style="color:var(--c)">AHRQ HCUP</a></div></div><div class="r" data-d="0.42" style="margin-top:36px"><div class="why-hero"><div class="why-stat"><div class="why-n">$504<span class="why-x">B</span></div><div class="why-l">Combined U.S. annual spending on the three conditions we monitor</div></div><div class="why-stat hot"><div class="why-n">5<span class="why-x">%</span></div><div class="why-l">Of patients drive 80% of your spending</div></div></div></div></div></section>

